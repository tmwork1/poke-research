{
	"name": "poke-research",
	"type": "module",
	"version": "0.0.1",
	"homepage": "https://poke-research.com",
	"license": "MIT",
	"engines": {
		"node": ">=22.15.0"
	},
	"scripts": {
		"dev": "astro dev",
		"migrate": "node ./scripts/db/run-migrations.mjs",
		"db:detect-duplicate-items": "node ./scripts/db/detect-duplicate-items.mjs",
		"db:detect-duplicate-sources": "node ./scripts/db/detect-duplicate-sources.mjs",
		"db:backfill-tag-explanations": "node ./scripts/db/backfill-tag-explanations.mjs",
		"db:retag-existing-items": "node ./scripts/db/retag-existing-items.mjs",
		"collect:qiita": "node ./scripts/collect/collect-qiita.mjs",
		"collect:zenn": "node ./scripts/collect/collect-zenn.mjs",
		"collect:note": "node ./scripts/collect/collect-note.mjs",
		"collect:blog": "node ./scripts/collect/collect-blog.mjs",
		"collect:hatena": "node ./scripts/collect/collect-hatena.mjs",
		"collect:check-links": "node ./scripts/collect/check-links.mjs",
		"collect:backfill": "node ./scripts/collect/backfill.mjs",
		"eval:collection": "node ./scripts/eval/eval-collection.mjs",
		"eval:collection:blog": "node ./scripts/eval/eval-collection-blog.mjs",
		"eval:collection:hatena": "node ./scripts/eval/eval-collection-hatena.mjs",
		"eval:search": "node ./scripts/eval/eval-search.mjs",
		"eval:filter": "node ./scripts/eval/eval-filter.mjs",
		"eval:tags": "node ./scripts/eval/eval-tags.mjs",
		"eval:annotations": "node ./scripts/eval/eval-annotations.mjs",
		"eval:broken-links": "node ./scripts/eval/eval-broken-links.mjs",
		"eval:all": "node ./scripts/eval/eval-all.mjs",
		"test": "node --test \"tests/**/*.test.ts\"",
		"build": "astro build",
		"preview": "astro build && astro preview",
		"astro": "astro",
		"generate-types": "wrangler types",
		"deploy": "astro build && wrangler deploy",
		"release": "node ./scripts/release.mjs",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^14.1.1",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.0.0",
		"astro": "^7.0.6",
		"pg": "^8.10.0"
	},
	"devDependencies": {
		"wrangler": "^4.107.0"
	}
}
