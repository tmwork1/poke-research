# ローカルSupabase / Postgres 接続設定例
# Supabase のローカルエミュレータがデフォルトポートで動作している想定

SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# Postgres 直接接続 (必要なら使用)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# 管理者操作（書き込み系 API、/api/audit）を保護する Basic 認証の資格情報
# 本番では wrangler secret put ADMIN_USERNAME / ADMIN_PASSWORD で設定する
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_admin_password_here

# レビュー用AI設定
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano

# [任意] Qiita 収集ジョブの既定条件
QIITA_PAGES=1
QIITA_PER_PAGE=10
# 1回の実行でAIレビュー・DB書き込みを行う新規記事数の上限（急増日のsubrequest数の頭打ち）。
# QIITA_MAX_NEW_PER_RUN=10

# [任意] Zenn 収集ジョブの既定条件
ZENN_PAGES=1
# ZENN_MAX_NEW_PER_RUN=8

# [任意] arXiv 収集ジョブの既定条件
# ARXIV_MAX_RESULTS=20
# ARXIV_MAX_NEW_PER_RUN=10

# [任意] はてなブックマーク収集ジョブの既定条件
# HATENA_MAX_CANDIDATES=15
# HATENA_MAX_NEW_PER_RUN=6

# [任意] RSSフィード追従ジョブの既定条件
# FEED_MAX_ENTRIES=10
# FEED_MAX_NEW_PER_RUN=10

# [任意] note 収集ジョブの既定条件
NOTE_PAGES=1
NOTE_PER_PAGE=10

# [任意] ブログ収集ジョブ（Brave Search API）の設定
# Brave Search 無料枠は月1000件（≒1日30件）。1日1回のcronで
# POKEMON_KEYWORDS（2語）× BLOG_PAGES を消費するため、既定は15（2語×15=30件/日）。
BRAVE_API_KEY=your_brave_api_key_here
BRAVE_COUNT=20
BLOG_PAGES=15
# BLOG_MAX_NEW_PER_RUN=6

# [任意] リンク切れ検出ジョブ（migrations/016）の負荷調整パラメータ
# 検索語のような品質直結の値ではないため、他ジョブと異なりここでの上書きを許容する。
# LINK_CHECK_BATCH_LIMITは未設定なら対象総数から自動算出される（resolveAdaptiveBatchLimit）ため、
# 動作確認等で固定値に上書きしたい場合のみ設定する。
# LINK_CHECK_BATCH_LIMIT=100
LINK_CHECK_CONCURRENCY=5
LINK_CHECK_RECHECK_DAYS=7
LINK_CHECK_TIMEOUT_MS=8000
