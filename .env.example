# ローカルSupabase / Postgres 接続設定例
# Supabase のローカルエミュレータがデフォルトポートで動作している想定

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Postgres 直接接続 (必要なら使用)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Qiita 取り込み時の AI レビュー設定
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano

# Qiita 収集ジョブの既定条件（未設定時は query=ポケモン, pages=1, perPage=20）
QIITA_QUERY=ポケモン
QIITA_PAGES=1
QIITA_PER_PAGE=20

# Zenn 収集ジョブの既定条件（未設定時は topic=pokemon, pages=1）
ZENN_TOPIC=pokemon
ZENN_PAGES=1

# note 収集ジョブの既定条件（未設定時は query=ポケモン, pages=1, perPage=10）
NOTE_QUERY=ポケモン
NOTE_PAGES=1
NOTE_PER_PAGE=10
