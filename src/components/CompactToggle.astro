---
---

<label class="compact-toggle">
	<input type="checkbox" class="compact-toggle-input" aria-label="AIによる要約を隠して圧縮表示にする" />
	<span class="switch" aria-hidden="true"></span>
	<span class="compact-toggle-label">圧縮表示</span>
</label>

<style>
	.compact-toggle {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		flex: none;
		cursor: pointer;
		user-select: none;
	}

	.compact-toggle-input {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.switch {
		position: relative;
		flex: none;
		width: 36px;
		height: 20px;
		border-radius: 999px;
		background: var(--border);
		transition: background-color 0.15s ease;
	}

	.switch::before {
		content: '';
		position: absolute;
		top: 2px;
		left: 2px;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: #fff;
		box-shadow: 0 1px 2px rgba(35, 35, 51, 0.25);
		transition: transform 0.15s ease;
	}

	.compact-toggle-input:checked + .switch {
		background: var(--accent);
	}

	.compact-toggle-input:checked + .switch::before {
		transform: translateX(16px);
	}

	.compact-toggle-input:focus-visible + .switch {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.compact-toggle-label {
		font-size: 0.78rem;
		color: var(--text-muted);
		letter-spacing: 0.02em;
		white-space: nowrap;
	}
</style>

<script>
	const STORAGE_KEY = 'pokeresearch:compact-view';

	function syncInputs(isCompact: boolean) {
		document.querySelectorAll<HTMLInputElement>('.compact-toggle-input').forEach((input) => {
			input.checked = isCompact;
		});
	}

	syncInputs(document.documentElement.classList.contains('compact-view'));

	document.querySelectorAll<HTMLInputElement>('.compact-toggle-input').forEach((input) => {
		input.addEventListener('change', () => {
			const isCompact = input.checked;
			document.documentElement.classList.toggle('compact-view', isCompact);
			try {
				localStorage.setItem(STORAGE_KEY, isCompact ? '1' : '0');
			} catch (error) {
				// localStorageが使用できない環境（プライベートブラウジング等）では保存をスキップする
			}
			syncInputs(isCompact);
		});
	});
</script>
