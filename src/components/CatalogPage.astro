---
import type { CatalogItem, SourceUsage, TagUsage } from '../lib/catalog';
import { tokenizeQuery } from '../lib/highlight';
import ItemCard from './ItemCard.astro';
import ItemListJsonLd from './ItemListJsonLd.astro';
import Pagination from './Pagination.astro';
import SortSelect from './SortSelect.astro';
import TagCloud from './TagCloud.astro';
import CompactToggle from './CompactToggle.astro';

interface Props {
	eyebrow?: string;
	basePath: string;
	items: CatalogItem[];
	topTags: TagUsage[];
	sources: SourceUsage[];
	filters: {
		q: string;
		tags: string[];
		sourceIds: number[];
		sort: string;
		period?: string;
	};
	pagination: {
		page: number;
		totalPages: number;
		total: number;
	};
	bookmarkedItemIds?: Set<number>;
	loggedIn?: boolean;
}

const {
	eyebrow,
	basePath,
	items,
	topTags,
	sources,
	filters,
	pagination,
	bookmarkedItemIds = new Set<number>(),
	loggedIn = false,
} = Astro.props as Props;

const highlightTokens = tokenizeQuery(filters.q);
const hasActiveFilters = Boolean(filters.q || filters.tags.length > 0 || filters.sourceIds.length > 0 || filters.period);

function buildUrl(overrides: Partial<{ q: string; tags: string[]; sourceIds: number[]; sort: string; period: string; page: number }>) {
	const q = overrides.q !== undefined ? overrides.q : filters.q;
	const tags = overrides.tags !== undefined ? overrides.tags : filters.tags;
	const sourceIds = overrides.sourceIds !== undefined ? overrides.sourceIds : filters.sourceIds;
	const sort = overrides.sort !== undefined ? overrides.sort : filters.sort;
	const period = overrides.period !== undefined ? overrides.period : (filters.period ?? '');
	const page = overrides.page;

	const params = new URLSearchParams();
	if (q) params.set('q', q);
	for (const tag of tags) params.append('tag', tag);
	for (const sourceId of sourceIds) params.append('sourceId', String(sourceId));
	if (sort && sort !== 'new') params.set('sort', sort);
	if (period) params.set('period', period);
	if (page && page > 1) params.set('page', String(page));

	const qs = params.toString();
	return qs ? `${basePath}?${qs}` : basePath;
}

function toggleSource(sourceId: number) {
	return filters.sourceIds.includes(sourceId)
		? filters.sourceIds.filter((id) => id !== sourceId)
		: [...filters.sourceIds, sourceId];
}
---

<section class="catalog">
	<ItemListJsonLd items={items} />
	{eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}

	<section class="panel">
		<form class="filters" method="get" action={basePath}>
			{filters.tags.map((tag) => <input type="hidden" name="tag" value={tag} />)}
			{filters.sourceIds.map((sourceId) => <input type="hidden" name="sourceId" value={sourceId} />)}
			<div class="search-row">
				<input class="search-input" type="search" name="q" value={filters.q} placeholder="キーワードで検索（例: ダメージ計算）" aria-label="キーワード" list="search-suggestions" />
				<a class="reset-link" href={basePath}>条件をリセット</a>
			</div>
			<datalist id="search-suggestions">
				{topTags.map((tag) => <option value={tag.name} />)}
			</datalist>

			<div class="filter-group">
				<p class="filter-label">ソース</p>
				<div class="chip-group" aria-label="公開元で絞り込む">
					<a class:list={['chip', { active: filters.sourceIds.length === 0 }]} href={buildUrl({ sourceIds: [] })}>すべて</a>
					{sources.map((source) => (
						<a class:list={['chip', { active: filters.sourceIds.includes(source.id) }]} href={buildUrl({ sourceIds: toggleSource(source.id) })}>
							{source.name} <span class="chip-count">{source.count}</span>
						</a>
					))}
				</div>
			</div>

			<div class="filter-group">
				<p class="filter-label">タグ（AND） <a class="tags-index-link" href="/tags">タグ一覧へ</a></p>
				<TagCloud topTags={topTags} activeTags={filters.tags} buildTagsUrl={(tags) => buildUrl({ tags, page: undefined })} multiSelect />
			</div>

			<div class="control-row">
				<SortSelect
					name="sort"
					ariaLabel="並び順"
					options={[
						...(filters.q ? [{ value: 'relevance', label: '関連度順', selected: filters.sort === 'relevance' }] : []),
						{ value: 'new', label: '新着順', selected: filters.sort === 'new' },
						{ value: 'popular', label: '人気順', selected: filters.sort === 'popular' },
						{ value: 'oldest', label: '古い順', selected: filters.sort === 'oldest' },
					]}
				/>

				<SortSelect
					name="period"
					ariaLabel="期間"
					icon="period"
					options={[
						{ value: '', label: '全期間', selected: !filters.period },
						{ value: '1m', label: '1ヶ月以内', selected: filters.period === '1m' },
						{ value: '6m', label: '半年以内', selected: filters.period === '6m' },
						{ value: '1y', label: '1年以内', selected: filters.period === '1y' },
					]}
				/>

				<span class="total-count">全{pagination.total}件</span>

				<div class="compact-toggle-slot"><CompactToggle /></div>
			</div>
		</form>

		<Pagination page={pagination.page} totalPages={pagination.totalPages} buildUrl={buildUrl} />

		{items.length > 0 ? (
			<div class="grid">
				{items.map((item) => (
					<ItemCard
						item={item}
						bookmarked={bookmarkedItemIds.has(item.id)}
						bookmarkCount={item.bookmarks_count ?? 0}
						loggedIn={loggedIn}
						highlightTokens={highlightTokens}
					/>
				))}
			</div>
		) : (
			<div class="empty-state">
				<h2>一致するアイテムがありません</h2>
				<p>条件を緩めるか、キーワードを変えて再検索してください。</p>
				{hasActiveFilters ? (
					<div class="fallback">
						<p class="fallback-label">条件を1つ外して探す:</p>
						<div class="chip-group">
							{filters.q ? <a class="chip" href={buildUrl({ q: '', page: undefined })}>キーワード「{filters.q}」を外す</a> : null}
							{filters.tags.map((tag) => (
								<a class="chip" href={buildUrl({ tags: filters.tags.filter((name) => name !== tag), page: undefined })}>タグ「{tag}」を外す</a>
							))}
							{filters.sourceIds.length > 0 ? <a class="chip" href={buildUrl({ sourceIds: [], page: undefined })}>ソースの絞り込みを外す</a> : null}
							{filters.period ? <a class="chip" href={buildUrl({ period: '', page: undefined })}>期間の絞り込みを外す</a> : null}
						</div>
					</div>
				) : null}
				{topTags.length > 0 ? (
					<div class="fallback">
						<p class="fallback-label">よく使われているタグから探す:</p>
						<div class="chip-group">
							{topTags.slice(0, 6).map((tag) => (
								<a class="chip" href={buildUrl({ q: '', tag: tag.name, sourceIds: [], period: '', page: undefined })}>#{tag.name}</a>
							))}
						</div>
					</div>
				) : null}
			</div>
		)}

		<Pagination page={pagination.page} totalPages={pagination.totalPages} buildUrl={buildUrl} />
	</section>
</section>

<style>
	/* grid-template-columns を省略すると暗黙列が内容の max-content 幅で決まり、
	   中の折り返し不可な要素（例: 検索欄の「条件をリセット」リンク）分だけ
	   コンテナ幅を超えて右にはみ出してしまう。1fr を明示してその崩れを防ぐ。 */
	.catalog {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 24px;
	}

	.empty-state {
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.eyebrow {
		margin: 0 0 4px;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.panel {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 20px;
	}

	.filters {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 14px;
	}

	.filter-group {
		display: grid;
		gap: 10px;
	}

	.filter-label {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.search-row {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.search-input {
		flex: 1;
		min-width: 0;
		box-sizing: border-box;
		padding: 14px 18px;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--card-bg);
		color: inherit;
		font-size: 1rem;
	}

	.control-row {
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
		padding-top: 18px;
		border-top: 1px solid var(--border);
	}

	.total-count {
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.fallback {
		margin-top: 16px;
	}

	.fallback-label {
		margin: 0 0 8px;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.reset-link {
		padding: 8px 14px;
		border-radius: 12px;
		background: var(--bg-soft);
		font-size: 0.85rem;
		flex: none;
		white-space: nowrap;
	}

	.chip-group {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		border-radius: 999px;
		background: var(--card-bg);
		border: 1px solid var(--border);
		color: var(--text);
		font-size: 0.88rem;
		text-decoration: none;
	}

	.chip:hover {
		border-color: var(--accent);
	}

	.chip.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.chip-count {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.chip.active .chip-count {
		color: rgba(255, 255, 255, 0.85);
	}

	.compact-toggle-slot {
		margin-left: auto;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 18px;
	}

	.empty-state {
		padding: 28px;
		border-radius: var(--radius-md);
	}

	.empty-state h2 {
		margin-top: 0;
	}

</style>
