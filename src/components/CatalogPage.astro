---
import type { CatalogItem, TagUsage } from '../lib/catalog';
import type { Source } from '../lib/db-types';
import ItemCard from './ItemCard.astro';

interface Props {
	title: string;
	eyebrow?: string;
	basePath: string;
	items: CatalogItem[];
	topTags: TagUsage[];
	sources: Source[];
	filters: {
		q: string;
		tag: string;
		sourceId: string;
	};
	pagination: {
		page: number;
		totalPages: number;
		total: number;
	};
	bookmarkedItemIds?: Set<number>;
	loggedIn?: boolean;
}

const {
	title,
	eyebrow,
	basePath,
	items,
	topTags,
	sources,
	filters,
	pagination,
	bookmarkedItemIds = new Set<number>(),
	loggedIn = false,
} = Astro.props as Props;

function buildUrl(overrides: Partial<{ q: string; tag: string; sourceId: string; page: number }>) {
	const q = overrides.q !== undefined ? overrides.q : filters.q;
	const tag = overrides.tag !== undefined ? overrides.tag : filters.tag;
	const sourceId = overrides.sourceId !== undefined ? overrides.sourceId : filters.sourceId;
	const page = overrides.page;

	const params = new URLSearchParams();
	if (q) params.set('q', q);
	if (tag) params.set('tag', tag);
	if (sourceId) params.set('sourceId', sourceId);
	if (page && page > 1) params.set('page', String(page));

	const qs = params.toString();
	return qs ? `${basePath}?${qs}` : basePath;
}

const prevPage = pagination.page - 1;
const nextPage = pagination.page + 1;
---

<section class="catalog">
	{eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
	<h1>{title}</h1>

	<form class="filters" method="get" action={basePath}>
		<input type="hidden" name="tag" value={filters.tag} />
		<label class="field-q">
			<span>キーワード</span>
			<input type="search" name="q" value={filters.q} placeholder="例: ダメージ計算" />
		</label>
		<label>
			<span>公開元</span>
			<select name="sourceId">
				<option value="" selected={!filters.sourceId}>すべて</option>
				{sources.map((source) => <option value={source.id} selected={filters.sourceId === String(source.id)}>{source.name}</option>)}
			</select>
		</label>
		<div class="actions">
			<button type="submit">絞り込む</button>
			<a href={basePath}>条件をリセット</a>
		</div>
	</form>

	{topTags.length > 0 ? (
		<div class="tag-cloud" aria-label="よく使われるタグ">
			<a class={`chip ${!filters.tag ? 'active' : ''}`} href={buildUrl({ tag: '' })}>すべて</a>
			{topTags.map((tag) => (
				<a class={`chip ${filters.tag === tag.name ? 'active' : ''}`} href={buildUrl({ tag: tag.name })}>
					{tag.name} <span class="chip-count">{tag.count}</span>
				</a>
			))}
		</div>
	) : null}

	{items.length > 0 ? (
		<div class="grid">
			{items.map((item) => <ItemCard item={item} bookmarked={bookmarkedItemIds.has(item.id)} loggedIn={loggedIn} />)}
		</div>
	) : (
		<div class="empty-state">
			<h2>一致するアイテムがありません</h2>
			<p>条件を緩めるか、キーワードを変えて再検索してください。</p>
		</div>
	)}

	{pagination.totalPages > 1 ? (
		<nav class="pagination" aria-label="ページ送り">
			{prevPage >= 1 ? <a href={buildUrl({ page: prevPage })}>前へ</a> : <span class="disabled">前へ</span>}
			<span class="page-indicator">{pagination.page} / {pagination.totalPages}</span>
			{nextPage <= pagination.totalPages ? <a href={buildUrl({ page: nextPage })}>次へ</a> : <span class="disabled">次へ</span>}
		</nav>
	) : null}
</section>

<style>
	.catalog {
		display: grid;
		gap: 24px;
	}

	.filters,
	.empty-state {
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.catalog h1 {
		margin: 0;
		font-size: clamp(1.8rem, 3.4vw, 2.6rem);
	}

	.eyebrow {
		margin: 0 0 4px;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.filters {
		display: grid;
		grid-template-columns: 2fr 1fr auto;
		align-items: end;
		gap: 16px;
		padding: 20px;
		border-radius: var(--radius-md);
	}

	.filters label {
		display: grid;
		gap: 8px;
	}

	.filters span {
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		color: var(--text-muted);
	}

	.filters input,
	.filters select {
		width: 100%;
		box-sizing: border-box;
		padding: 12px 14px;
		border: 1px solid var(--border);
		border-radius: 12px;
		background: #fff;
		color: inherit;
		font-size: 0.95rem;
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-wrap: wrap;
	}

	.actions button,
	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 12px 16px;
		border-radius: 12px;
		border: 1px solid var(--border);
	}

	.actions button {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
		font-weight: 700;
	}

	.actions a {
		background: var(--bg-soft);
	}

	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		border-radius: 999px;
		background: var(--card-bg);
		border: 1px solid var(--border);
		color: var(--text);
		font-size: 0.88rem;
	}

	.chip:hover {
		border-color: var(--accent);
	}

	.chip.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.chip-count {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.chip.active .chip-count {
		color: rgba(255, 255, 255, 0.85);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.empty-state {
		padding: 28px;
		border-radius: var(--radius-lg);
	}

	.empty-state h2 {
		margin-top: 0;
	}

	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
	}

	.pagination a,
	.pagination .disabled {
		padding: 10px 18px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--card-bg);
	}

	.pagination .disabled {
		color: var(--text-muted);
		opacity: 0.5;
	}

	.page-indicator {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	@media (max-width: 960px) {
		.filters,
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
