---
import type { TagUsage } from '../lib/catalog';
import { formatTagLabel } from '../lib/tag-display';

interface Props {
	topTags: TagUsage[];
	/** 現在アクティブなタグ名の一覧（単一選択の画面は0〜1件で渡す）。 */
	activeTags: string[];
	/** 選択後のタグ集合から遷移先URLを組み立てる。 */
	buildTagsUrl: (tags: string[]) => string;
	/** true なら複数タグの AND 選択（クリックでトグル）。false なら単一選択。 */
	multiSelect?: boolean;
}

const { topTags, activeTags, buildTagsUrl, multiSelect = false } = Astro.props as Props;

function toggledTags(tagName: string): string[] {
	if (!multiSelect) {
		return activeTags.includes(tagName) ? [] : [tagName];
	}
	return activeTags.includes(tagName)
		? activeTags.filter((name) => name !== tagName)
		: [...activeTags, tagName];
}
---

{topTags.length > 0 ? (
	<div class="tag-cloud" aria-label="よく使われるタグ">
		<a class={`chip ${activeTags.length === 0 ? 'active' : ''}`} href={buildTagsUrl([])}>すべて</a>
		{topTags.map((tag) => (
			<a class={`chip ${activeTags.includes(tag.name) ? 'active' : ''}`} href={buildTagsUrl(toggledTags(tag.name))}>
				{formatTagLabel(tag.name)} <span class="chip-count">{tag.count}</span>
			</a>
		))}
	</div>
) : null}

<style>
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		border-radius: 999px;
		background: var(--card-bg);
		border: 1px solid var(--border);
		color: var(--text);
		font-size: 0.88rem;
		text-decoration: none;
	}

	.chip:hover {
		border-color: var(--accent);
	}

	.chip.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	.chip-count {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.chip.active .chip-count {
		color: rgba(255, 255, 255, 0.85);
	}
</style>
