---
import type { CatalogItem } from '../lib/catalog';
import { splitForHighlight } from '../lib/highlight';
import { formatTagLabel } from '../lib/tag-display';

interface Props {
	item: CatalogItem;
	bookmarked?: boolean;
	loggedIn?: boolean;
	bookmarkCount?: number;
	/** 検索キーワード。指定するとタイトル・要約内の一致箇所を <mark> で強調する。 */
	highlightTokens?: string[];
}

const { item, bookmarked = false, loggedIn = false, bookmarkCount = 0, highlightTokens = [] } = Astro.props as Props;

const formatDate = new Intl.DateTimeFormat('ja-JP', {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
});

function formatDateLabel(value?: string | null) {
	if (!value) return '未設定';
	return formatDate.format(new Date(value));
}

function extractDomain(url?: string | null): string | null {
	if (!url) return null;
	try {
		return new URL(url).hostname.replace(/^www\./, '');
	} catch {
		return null;
	}
}

const title = item.title || `Item ${item.id}`;
const titleSegments = splitForHighlight(title, highlightTokens);
const summarySegments = item.summary ? splitForHighlight(item.summary, highlightTokens) : [];

const shareUrl = item.external_url
	? `https://twitter.com/intent/tweet?url=${encodeURIComponent(item.external_url)}&text=${encodeURIComponent(title)}`
	: null;

// ソース種別ごとの色チップ表示用。blog は個別のブログ名を持たないため、外部リンクのドメインで代替する。
const sourceType = item.source?.type ?? 'blog';
const sourceDomain = extractDomain(item.external_url);
const sourceLabel = sourceType === 'blog' ? (sourceDomain ?? item.source?.name ?? null) : (item.source?.name ?? null);

// 元記事の公開日から一定期間以上経って更新されている場合のみ「更新あり」を出す（取り込み時刻の揺れをノイズとして拾わないため）。
const publishedAtValue = item.published_at ?? item.created_at;
const updatedAtValue = item.updated_at;
const UPDATED_BADGE_THRESHOLD_MS = 7 * 24 * 60 * 60 * 1000;
const showUpdatedBadge = Boolean(
	publishedAtValue && updatedAtValue && new Date(updatedAtValue).getTime() - new Date(publishedAtValue).getTime() >= UPDATED_BADGE_THRESHOLD_MS,
);
---

<article class="card" data-item-id={item.id}>
	<div class="card-head">
		{item.external_url ? (
			<a class="item-title" href={item.external_url} target="_blank" rel="noreferrer">{titleSegments.map((seg) => (seg.hit ? <mark>{seg.text}</mark> : seg.text))}</a>
		) : (
			<p class="item-title">{titleSegments.map((seg) => (seg.hit ? <mark>{seg.text}</mark> : seg.text))}</p>
		)}
		<div class="card-actions">
			{shareUrl ? (
				<a
					class="share-button"
					href={shareUrl}
					target="_blank"
					rel="noreferrer"
					aria-label="共有"
					data-share-title={title}
					data-share-url={item.external_url}
				>
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="18" cy="5" r="3" />
						<circle cx="6" cy="12" r="3" />
						<circle cx="18" cy="19" r="3" />
						<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
						<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
					</svg>
				</a>
			) : null}
			{item.external_url ? (
				<button type="button" class="copy-link-button" data-url={item.external_url} aria-label="リンクをコピー">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="9" y="9" width="11" height="11" rx="2" />
						<path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1" />
					</svg>
				</button>
			) : null}
			<div class="bookmark-wrap">
				<button
					type="button"
					class:list={['bookmark-toggle', { active: bookmarked }]}
					data-item-id={item.id}
					data-bookmarked={bookmarked ? 'true' : 'false'}
					data-logged-in={loggedIn ? 'true' : 'false'}
					aria-pressed={bookmarked ? 'true' : 'false'}
					aria-label={bookmarked ? 'お気に入りから削除' : 'お気に入りに追加'}
				>
					<svg viewBox="0 0 24 24" width="18" height="18" fill={bookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z" />
					</svg>
				</button>
				<span class="bookmark-count" aria-label={`${bookmarkCount}件がブックマーク`}>{bookmarkCount}</span>
			</div>
		</div>
	</div>
	<p class="summary">
		{item.summary ? <span class="ai-badge" title="この要約はAIによる自動生成です">AI要約</span> : null}
		{item.summary ? summarySegments.map((seg) => (seg.hit ? <mark>{seg.text}</mark> : seg.text)) : '要約はまだ登録されていません。'}
	</p>
	<div class="tag-row">
		{item.tags.length > 0 ? (
			<div class="tag-list">
				{item.tags.map((tag) => (
					<span class="tag" data-tag-id={tag.id} tabindex="0" role="button" aria-expanded="false">
						#{formatTagLabel(tag.name)}
					</span>
				))}
			</div>
		) : (
			<p class="empty-tags">タグ未設定</p>
		)}
		<div class="footer-meta">
			<span class="card-date">{formatDateLabel(publishedAtValue)}</span>
			{showUpdatedBadge ? (
				<span class="updated-badge" title={`更新日: ${formatDateLabel(updatedAtValue)}`}>更新あり</span>
			) : null}
			{item.authors && item.authors.length > 0 ? (
				<span class="byline">{item.authors.join(', ')}</span>
			) : null}
			{sourceLabel ? (
				<span class="source-chip" data-source-type={sourceType}>{sourceLabel}</span>
			) : null}
		</div>
	</div>
</article>

<style>
	.card {
		display: grid;
		gap: 14px;
		padding: 22px;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.card-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 12px;
	}

	.item-title {
		margin: 0;
		font-size: 1.3rem;
		font-weight: 700;
		line-height: 1.4;
		color: var(--text);
	}

	a.item-title:hover {
		color: var(--accent-dark);
	}

	.card-actions {
		flex: none;
		display: flex;
		align-items: flex-start;
		gap: 8px;
	}

	.bookmark-wrap {
		flex: none;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	.share-button {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--card-bg);
		color: var(--text-muted);
	}

	.share-button:hover {
		border-color: var(--accent);
		color: var(--accent-dark);
	}

	.copy-link-button {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--card-bg);
		color: var(--text-muted);
		cursor: pointer;
	}

	.copy-link-button:hover {
		border-color: var(--accent);
		color: var(--accent-dark);
	}

	.bookmark-toggle {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--card-bg);
		color: var(--text-muted);
		cursor: pointer;
	}

	.bookmark-count {
		font-size: 0.72rem;
		color: var(--text-muted);
		line-height: 1;
	}

	.bookmark-toggle:hover {
		border-color: var(--accent);
		color: var(--accent-dark);
	}

	.bookmark-toggle.active {
		color: var(--accent-dark);
	}

	.summary {
		margin: 0;
		color: var(--text-muted);
		line-height: 1.7;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	mark {
		background: var(--mark-bg);
		color: inherit;
		border-radius: 3px;
		padding: 0 1px;
	}

	/* 要約がAI生成であることの出所表示（provenance 重視の方針に合わせる）。 */
	.ai-badge {
		display: inline-block;
		margin-right: 6px;
		padding: 1px 8px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-size: 0.7rem;
		line-height: 1.6;
		color: var(--text-muted);
		background: var(--bg-soft);
		vertical-align: 2px;
	}

	:global(.compact-view) .summary {
		display: none;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.tag-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 4px;
	}

	.footer-meta {
		flex: none;
		display: flex;
		align-items: baseline;
		gap: 8px;
		white-space: nowrap;
	}

	.card-date {
		flex: none;
		white-space: nowrap;
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	.byline {
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	.updated-badge {
		flex: none;
		padding: 1px 8px;
		border-radius: 999px;
		background: var(--bg-soft);
		color: var(--text-muted);
		font-size: 0.7rem;
		line-height: 1.6;
		white-space: nowrap;
	}

	/* ソース種別ごとの色チップ。透明度ベースの背景にすることで、ライト/ダーク両方の背景色に馴染ませる。 */
	.source-chip {
		flex: none;
		padding: 1px 8px;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		line-height: 1.6;
		white-space: nowrap;
		background: rgba(120, 120, 120, 0.15);
		color: var(--text-muted);
	}

	.source-chip[data-source-type='qiita'] {
		background: rgba(85, 197, 0, 0.15);
		color: #3f8f00;
	}

	.source-chip[data-source-type='zenn'] {
		background: rgba(62, 168, 255, 0.15);
		color: #1f78d1;
	}

	.source-chip[data-source-type='note'] {
		background: rgba(65, 201, 180, 0.15);
		color: #1f8a77;
	}

	@media (prefers-color-scheme: dark) {
		.source-chip[data-source-type='qiita'] {
			color: #8be04e;
		}

		.source-chip[data-source-type='zenn'] {
			color: #7cc4ff;
		}

		.source-chip[data-source-type='note'] {
			color: #7fe0cf;
		}
	}

	/* 既読カードはタイトルの視覚的な優先度だけ下げ、要約や他情報はそのまま残す。 */
	.card.read .item-title {
		color: var(--text-muted);
	}

	.tag,
	.empty-tags {
		padding: 6px 10px;
		border-radius: 999px;
		background: var(--bg-soft);
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	.tag {
		position: relative;
	}

	/* 解説が登録済みのタグは、クリックで説明が読めることが分かるよう下線+ヘルプカーソルで示す。 */
	.tag.has-explanation {
		cursor: help;
		text-decoration: underline dotted;
		text-underline-offset: 3px;
	}

	.tag-popover {
		position: absolute;
		z-index: 100;
		top: calc(100% + 6px);
		left: 0;
		width: max-content;
		max-width: 260px;
		padding: 10px 12px;
		border-radius: var(--radius-md);
		border: 1px solid var(--border);
		background: var(--card-bg);
		color: var(--text);
		font-size: 0.82rem;
		line-height: 1.6;
		font-weight: 400;
		white-space: normal;
		box-shadow: var(--shadow);
	}

	/* トーストは JS で body 直下に生成するため、スコープ外の :global で当てる。 */
	:global(.app-toast) {
		position: fixed;
		left: 50%;
		bottom: 24px;
		transform: translateX(-50%) translateY(8px);
		padding: 10px 18px;
		border-radius: 8px;
		background: rgba(30, 30, 30, 0.92);
		color: #fff;
		font-size: 0.88rem;
		line-height: 1.5;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease, transform 0.2s ease;
		z-index: 1000;
	}

	:global(.app-toast.visible) {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}
</style>

<script>
	let toastTimer: ReturnType<typeof setTimeout> | undefined;

	function showToast(message: string) {
		// 失敗を console だけに残すとユーザーには無言の失敗になるため、画面にも短く出す。
		let toast = document.querySelector<HTMLDivElement>('.app-toast');
		if (!toast) {
			toast = document.createElement('div');
			toast.className = 'app-toast';
			toast.setAttribute('role', 'alert');
			document.body.appendChild(toast);
		}
		toast.textContent = message;
		toast.classList.add('visible');
		if (toastTimer) clearTimeout(toastTimer);
		toastTimer = setTimeout(() => toast?.classList.remove('visible'), 3000);
	}

	function bindBookmarkToggle(button: HTMLButtonElement) {
		if (button.dataset.bound === 'true') return;
		button.dataset.bound = 'true';

		button.addEventListener('click', async () => {
			if (button.dataset.loggedIn !== 'true') {
				window.location.href = '/api/auth/login';
				return;
			}

			const itemId = button.dataset.itemId;
			const wasBookmarked = button.dataset.bookmarked === 'true';
			button.disabled = true;
			try {
				const response = wasBookmarked
					? await fetch(`/api/bookmarks/${itemId}`, { method: 'DELETE' })
					: await fetch('/api/bookmarks', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ itemId: Number(itemId) }),
						});
				if (!response.ok) throw new Error(`bookmark request failed: ${response.status}`);

				const nowBookmarked = !wasBookmarked;
				button.dataset.bookmarked = String(nowBookmarked);
				button.setAttribute('aria-pressed', String(nowBookmarked));
				button.setAttribute('aria-label', nowBookmarked ? 'お気に入りから削除' : 'お気に入りに追加');
				button.classList.toggle('active', nowBookmarked);
				const svg = button.querySelector('svg');
				svg?.setAttribute('fill', nowBookmarked ? 'currentColor' : 'none');

				const countEl = button.parentElement?.querySelector<HTMLSpanElement>('.bookmark-count');
				if (countEl) {
					const current = Number(countEl.textContent) || 0;
					const next = Math.max(0, current + (nowBookmarked ? 1 : -1));
					countEl.textContent = String(next);
					countEl.setAttribute('aria-label', `${next}件がブックマーク`);
				}
			} catch (error) {
				console.error('Failed to toggle bookmark:', error);
				showToast(wasBookmarked ? 'お気に入りの削除に失敗しました' : 'お気に入りの保存に失敗しました');
			} finally {
				button.disabled = false;
			}
		});
	}

	document.querySelectorAll<HTMLButtonElement>('.bookmark-toggle').forEach(bindBookmarkToggle);

	function bindShareButton(link: HTMLAnchorElement) {
		if (link.dataset.bound === 'true') return;
		link.dataset.bound = 'true';

		link.addEventListener('click', (event) => {
			// navigator.share が使える環境では OS の共有シートを優先し、使えない場合のみ href の X intent へ遷移させる。
			if (typeof navigator.share !== 'function') return;
			event.preventDefault();
			const shareTitle = link.dataset.shareTitle ?? document.title;
			const shareUrl = link.dataset.shareUrl ?? link.href;
			navigator.share({ title: shareTitle, url: shareUrl }).catch(() => {
				// ユーザーによるキャンセルなどは想定内のため、エラー表示はしない。
			});
		});
	}

	document.querySelectorAll<HTMLAnchorElement>('.share-button').forEach(bindShareButton);

	function bindCopyLinkButton(button: HTMLButtonElement) {
		if (button.dataset.bound === 'true') return;
		button.dataset.bound = 'true';

		button.addEventListener('click', async () => {
			const url = button.dataset.url;
			if (!url) return;
			try {
				await navigator.clipboard.writeText(url);
				showToast('リンクをコピーしました');
			} catch (error) {
				console.error('Failed to copy link:', error);
				showToast('リンクのコピーに失敗しました');
			}
		});
	}

	document.querySelectorAll<HTMLButtonElement>('.copy-link-button').forEach(bindCopyLinkButton);

	// 既読状態は localStorage にのみ保持し、サーバー側の状態とは連動させない（軽量な閲覧補助のため）。
	const READ_ITEMS_STORAGE_KEY = 'pokeresearch:read-items';
	const READ_ITEMS_LIMIT = 500;

	function getReadItemIds(): string[] {
		try {
			const raw = localStorage.getItem(READ_ITEMS_STORAGE_KEY);
			if (!raw) return [];
			const parsed = JSON.parse(raw);
			if (!Array.isArray(parsed)) return [];
			return parsed.filter((value): value is string => typeof value === 'string');
		} catch (error) {
			console.error('Failed to read read-items state:', error);
			return [];
		}
	}

	function markItemAsRead(itemId: string) {
		try {
			const ids = getReadItemIds().filter((id) => id !== itemId);
			ids.push(itemId);
			const trimmed = ids.slice(-READ_ITEMS_LIMIT);
			localStorage.setItem(READ_ITEMS_STORAGE_KEY, JSON.stringify(trimmed));
		} catch (error) {
			console.error('Failed to save read-items state:', error);
		}
	}

	function applyReadState(card: HTMLElement) {
		const itemId = card.dataset.itemId;
		if (!itemId) return;
		if (getReadItemIds().includes(itemId)) {
			card.classList.add('read');
		}
	}

	function bindTitleReadTracking(link: HTMLAnchorElement) {
		if (link.dataset.readBound === 'true') return;
		link.dataset.readBound = 'true';

		link.addEventListener('click', () => {
			const card = link.closest<HTMLElement>('.card[data-item-id]');
			const itemId = card?.dataset.itemId;
			if (!itemId) return;
			markItemAsRead(itemId);
			card?.classList.add('read');
		});
	}

	document.querySelectorAll<HTMLElement>('.card[data-item-id]').forEach(applyReadState);
	document.querySelectorAll<HTMLAnchorElement>('a.item-title').forEach(bindTitleReadTracking);

	// タグ解説: 画面上のタグを一括でバッチAPIに問い合わせ、キャッシュ済みの解説だけを先読みする。
	// 未生成のタグはクリック時にオンデマンドで /api/tags/{id}/explain を叩く（AI生成を含むため遅い）。
	type TagExplanation = { isDifficult: boolean; explanation: string | null };

	const tagExplanationCache = new Map<string, TagExplanation>();
	const batchCheckedTagIds = new Set<string>();
	const onDemandRequests = new Map<string, Promise<TagExplanation | null>>();
	const TAG_EXPLANATION_BATCH_SIZE = 50;

	function applyExplanationHint(el: HTMLElement, result: TagExplanation | undefined) {
		el.classList.toggle('has-explanation', Boolean(result?.isDifficult && result.explanation));
	}

	function applyHintsForKnownTags() {
		document.querySelectorAll<HTMLElement>('.tag[data-tag-id]').forEach((el) => {
			const tagId = el.dataset.tagId;
			if (!tagId) return;
			const result = tagExplanationCache.get(tagId);
			if (result) applyExplanationHint(el, result);
		});
	}

	async function batchFetchTagExplanations(tagIds: string[]) {
		const idsToFetch = [...new Set(tagIds)].filter((id) => !batchCheckedTagIds.has(id));
		if (idsToFetch.length === 0) return;
		idsToFetch.forEach((id) => batchCheckedTagIds.add(id));

		for (let i = 0; i < idsToFetch.length; i += TAG_EXPLANATION_BATCH_SIZE) {
			const chunk = idsToFetch.slice(i, i + TAG_EXPLANATION_BATCH_SIZE);
			try {
				const response = await fetch(`/api/tags/explanations?ids=${chunk.join(',')}`);
				if (!response.ok) continue;
				const json = await response.json();
				const data = (json?.data ?? {}) as Record<string, TagExplanation>;
				for (const [tagId, result] of Object.entries(data)) {
					tagExplanationCache.set(tagId, result);
				}
			} catch (error) {
				console.error('Failed to batch-fetch tag explanations:', error);
			}
		}
		applyHintsForKnownTags();
	}

	function scanForTagExplanations(root: ParentNode) {
		const ids = new Set<string>();
		root.querySelectorAll<HTMLElement>('.tag[data-tag-id]').forEach((el) => {
			const tagId = el.dataset.tagId;
			if (tagId) ids.add(tagId);
		});
		if (ids.size > 0) void batchFetchTagExplanations([...ids]);
	}

	let activeTagPopover: { el: HTMLDivElement; tag: HTMLElement } | null = null;

	function closeTagPopover() {
		if (!activeTagPopover) return;
		activeTagPopover.el.remove();
		activeTagPopover.tag.setAttribute('aria-expanded', 'false');
		activeTagPopover = null;
	}

	function openTagPopover(tag: HTMLElement, explanation: string) {
		closeTagPopover();
		const popover = document.createElement('div');
		popover.className = 'tag-popover';
		popover.setAttribute('role', 'tooltip');
		popover.textContent = explanation;
		tag.appendChild(popover);
		tag.setAttribute('aria-expanded', 'true');
		activeTagPopover = { el: popover, tag };
	}

	document.addEventListener('click', (event) => {
		if (!activeTagPopover) return;
		if (activeTagPopover.tag.contains(event.target as Node)) return;
		closeTagPopover();
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && activeTagPopover) closeTagPopover();
	});

	async function handleTagActivate(tag: HTMLElement) {
		const tagId = tag.dataset.tagId;
		if (!tagId) return;

		if (activeTagPopover?.tag === tag) {
			closeTagPopover();
			return;
		}

		const cached = tagExplanationCache.get(tagId);
		if (cached) {
			if (cached.isDifficult && cached.explanation) openTagPopover(tag, cached.explanation);
			return;
		}

		if (!onDemandRequests.has(tagId)) {
			const promise = fetch(`/api/tags/${tagId}/explain`)
				.then((response) => (response.ok ? response.json() : null))
				.then((json) => (json?.data ?? null) as TagExplanation | null)
				.catch(() => null);
			onDemandRequests.set(tagId, promise);
		}
		const result = await onDemandRequests.get(tagId)!;
		onDemandRequests.delete(tagId);
		if (!result) return;

		tagExplanationCache.set(tagId, result);
		batchCheckedTagIds.add(tagId);
		applyExplanationHint(tag, result);
		if (result.isDifficult && result.explanation) openTagPopover(tag, result.explanation);
	}

	function bindTagPopover(el: HTMLElement) {
		if (el.dataset.popoverBound === 'true') return;
		el.dataset.popoverBound = 'true';

		el.addEventListener('click', () => {
			void handleTagActivate(el);
		});
		el.addEventListener('keydown', (event) => {
			if (event.key === 'Enter' || event.key === ' ') {
				event.preventDefault();
				void handleTagActivate(el);
			}
		});
	}

	document.querySelectorAll<HTMLElement>('.tag[data-tag-id]').forEach(bindTagPopover);
	scanForTagExplanations(document);

	// 無限スクロールなどでカードが動的に追加される画面向けに、新規ノードのボタン/タグにも同じバインドを行う。
	const dynamicBindObserver = new MutationObserver((mutations) => {
		const newTagRoots: ParentNode[] = [];
		for (const mutation of mutations) {
			for (const node of mutation.addedNodes) {
				if (!(node instanceof HTMLElement)) continue;
				if (node.matches('.bookmark-toggle')) bindBookmarkToggle(node as HTMLButtonElement);
				if (node.matches('.tag[data-tag-id]')) bindTagPopover(node);
				if (node.matches('.share-button')) bindShareButton(node as HTMLAnchorElement);
				if (node.matches('.copy-link-button')) bindCopyLinkButton(node as HTMLButtonElement);
				if (node.matches('.card[data-item-id]')) applyReadState(node);
				if (node.matches('a.item-title')) bindTitleReadTracking(node as HTMLAnchorElement);
				node.querySelectorAll<HTMLButtonElement>('.bookmark-toggle').forEach(bindBookmarkToggle);
				node.querySelectorAll<HTMLElement>('.tag[data-tag-id]').forEach(bindTagPopover);
				node.querySelectorAll<HTMLAnchorElement>('.share-button').forEach(bindShareButton);
				node.querySelectorAll<HTMLButtonElement>('.copy-link-button').forEach(bindCopyLinkButton);
				node.querySelectorAll<HTMLElement>('.card[data-item-id]').forEach(applyReadState);
				node.querySelectorAll<HTMLAnchorElement>('a.item-title').forEach(bindTitleReadTracking);
				newTagRoots.push(node);
			}
		}
		if (newTagRoots.length > 0) {
			const ids = new Set<string>();
			for (const root of newTagRoots) {
				if (root instanceof HTMLElement && root.matches('.tag[data-tag-id]')) {
					const tagId = root.dataset.tagId;
					if (tagId) ids.add(tagId);
				}
				root.querySelectorAll<HTMLElement>('.tag[data-tag-id]').forEach((el) => {
					const tagId = el.dataset.tagId;
					if (tagId) ids.add(tagId);
				});
			}
			if (ids.size > 0) void batchFetchTagExplanations([...ids]);
		}
	});
	dynamicBindObserver.observe(document.body, { childList: true, subtree: true });
</script>
