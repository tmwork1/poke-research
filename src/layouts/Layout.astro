---
const {
	title = 'PokeResearch',
	description = 'ポケモンプログラミング情報ハブのローカル開発環境',
	loggedIn = false,
	// SVG を無視するクローラー・SNS があるため、共有用画像は PNG を既定にする。
	ogImage = '/og-image.png',
} = Astro.props;

const user = Astro.locals.user;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const shareText = 'ポケモン×プログラミングの記事をまとめた情報ハブです';
const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(canonicalUrl.toString())}`;

// サイト全体の構造化データ。検索エンジンにサイト内検索(/items?q=)の存在も伝える。
const websiteJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'PokeResearch',
	description: 'ポケモンに関するプログラミング・開発の技術記事を自動収集する情報ハブ',
	url: Astro.site?.toString(),
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: `${Astro.site?.toString().replace(/\/$/, '')}/items?q={search_term_string}`,
		},
		'query-input': 'required name=search_term_string',
	},
});
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				try {
					if (localStorage.getItem('pokeresearch:compact-view') === '1') {
						document.documentElement.classList.add('compact-view');
					}
				} catch (error) {
					// localStorageが使用できない環境では通常表示のままにする
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="alternate" type="application/rss+xml" title="PokeResearch 新着" href="/rss.xml" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl.toString()} />
		<meta property="og:image" content={ogImageUrl.toString()} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl.toString()} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={websiteJsonLd} />
	</head>
	<body>
		<div class="shell">
			<header class="topbar">
				<div class="brand-row">
					<button
						type="button"
						class="menu-toggle"
						aria-label="メニューを開く"
						aria-expanded="false"
						aria-controls="sidebar-panel"
						id="sidebar-toggle"
					>
						<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 6h16" />
							<path d="M4 12h16" />
							<path d="M4 18h16" />
						</svg>
					</button>
					<a class="brand" href="/">Poke<span class="brand-r">R</span>esearch</a>
				</div>
				<nav class="tab-nav" aria-label="Primary">
					<a class:list={['nav-tab', { current: pathname === '/' }]} href="/" aria-current={pathname === '/' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M3 11l9-8 9 8" />
							<path d="M5 10v10h14V10" />
						</svg>
						<span>ホーム</span>
					</a>
					<a class:list={['nav-tab', { current: pathname === '/items' }]} href="/items" aria-current={pathname === '/items' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="11" cy="11" r="7" />
							<path d="M21 21l-4.3-4.3" />
						</svg>
						<span>検索</span>
					</a>
					<div class="mypage-tab-wrap">
						<a class:list={['nav-tab', 'mypage-tab', { 'logged-in': loggedIn, current: pathname === '/mypage' }]} href="/mypage" aria-current={pathname === '/mypage' ? 'page' : undefined}>
							<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="8" r="4" />
								<path d="M4 20c0-4 3.5-7 8-7s8 3 8 7" />
							</svg>
							<span>マイページ</span>
						</a>
						{user ? (
							<div class="account-dropdown">
								<p class="dropdown-name">{user.displayName ?? user.email ?? 'ログイン中'}</p>
								{user.email ? <p class="dropdown-email">{user.email}</p> : null}
								<form method="post" action="/api/auth/logout">
									<button type="submit">ログアウト</button>
								</form>
							</div>
						) : null}
					</div>
				</nav>
			</header>
			<main class="page">
				<slot />
			</main>
		</div>
		<div class="sidebar-overlay" id="sidebar-overlay" hidden></div>
		<aside class="sidebar" id="sidebar-panel" aria-hidden="true" aria-label="メニュー">
			<div class="sidebar-header">
				<button type="button" class="sidebar-close" id="sidebar-close" aria-label="メニューを閉じる">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M6 6l12 12" />
						<path d="M18 6L6 18" />
					</svg>
				</button>
			</div>
			<p class="sidebar-about">ポケモンプログラミングに関する記事を自動で収集・整理する情報ハブです</p>
			<ul class="sidebar-links">
				<li>
					<a href="/about">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="9" />
							<path d="M12 8h.01" />
							<path d="M11 12h1v4h1" />
						</svg>
						<span>このサイトについて</span>
					</a>
				</li>
				<li>
					<a href={shareUrl} target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="18" cy="5" r="3" />
							<circle cx="6" cy="12" r="3" />
							<circle cx="18" cy="19" r="3" />
							<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
							<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
						</svg>
						<span>このサイトを共有</span>
					</a>
				</li>
				<li>
					<a href="https://x.com/ml7ddw0" target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 4h16v16H4z" opacity="0" />
							<path d="M22 5.5c-.8.4-1.6.6-2.5.7a4.3 4.3 0 0 0 1.9-2.4c-.9.5-1.8.9-2.8 1.1a4.2 4.2 0 0 0-7.3 3.8A12 12 0 0 1 2.9 4.3a4.2 4.2 0 0 0 1.3 5.6c-.7 0-1.4-.2-2-.5v.1a4.2 4.2 0 0 0 3.4 4.1c-.6.2-1.3.2-1.9.1a4.2 4.2 0 0 0 3.9 2.9A8.5 8.5 0 0 1 2 18.4a12 12 0 0 0 6.5 1.9c7.8 0 12-6.4 12-12v-.5c.8-.6 1.5-1.3 2-2.2z" fill="currentColor" stroke="none" />
						</svg>
						<span class="sidebar-link-text">
							<span>コンタクト</span>
							<span class="sidebar-link-handle">@ml7ddw0</span>
						</span>
					</a>
				</li>
				<li class="sidebar-divider" role="separator"></li>
				<li>
					<a href="/api/export/items.csv">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 3v12" />
							<path d="M7 10l5 5 5-5" />
							<path d="M4 19h16" />
						</svg>
						<span>CSVエクスポート</span>
					</a>
				</li>
				<li>
					<a href="/rss.xml">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 11a9 9 0 0 1 9 9" />
							<path d="M4 4a16 16 0 0 1 16 16" />
							<circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
						</svg>
						<span>RSSで購読</span>
					</a>
				</li>
			</ul>
			<div class="sidebar-account">
				{user ? (
					<>
						<p class="sidebar-account-name">{user.displayName ?? user.email ?? 'ログイン中'}</p>
						{user.email ? <p class="sidebar-account-email">{user.email}</p> : null}
						<form method="post" action="/api/auth/logout">
							<button type="submit" class="sidebar-logout">ログアウト</button>
						</form>
					</>
				) : (
					<a class="sidebar-login" href="/api/auth/login">Googleでログイン</a>
				)}
			</div>
		</aside>
	</body>
</html>

<script>
	const toggle = document.getElementById('sidebar-toggle');
	const closeBtn = document.getElementById('sidebar-close');
	const overlay = document.getElementById('sidebar-overlay');
	const sidebar = document.getElementById('sidebar-panel');

	function openSidebar() {
		sidebar?.classList.add('open');
		overlay?.removeAttribute('hidden');
		requestAnimationFrame(() => overlay?.classList.add('open'));
		toggle?.setAttribute('aria-expanded', 'true');
		sidebar?.setAttribute('aria-hidden', 'false');
	}

	function closeSidebar() {
		sidebar?.classList.remove('open');
		overlay?.classList.remove('open');
		toggle?.setAttribute('aria-expanded', 'false');
		sidebar?.setAttribute('aria-hidden', 'true');
		setTimeout(() => overlay?.setAttribute('hidden', ''), 200);
	}

	toggle?.addEventListener('click', () => {
		const isOpen = sidebar?.classList.contains('open');
		if (isOpen) {
			closeSidebar();
		} else {
			openSidebar();
		}
	});

	closeBtn?.addEventListener('click', closeSidebar);
	overlay?.addEventListener('click', closeSidebar);

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && sidebar?.classList.contains('open')) {
			closeSidebar();
		}
	});
</script>

<style>
	:global(:root) {
		color-scheme: light;
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;

		--bg: #f6f8fa;
		--bg-soft: #eef1f4;
		--card-bg: #ffffff;
		--border: #e3e7eb;
		--text: #232333;
		--text-muted: #6a737d;
		--accent: #1f9e7a;
		--accent-dark: #157a5e;
		--radius-lg: 20px;
		--radius-md: 14px;
		--shadow: 0 4px 16px rgba(35, 35, 51, 0.06);

		background: var(--bg);
		color: var(--text);
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		width: 100%;
	}

	body {
		background: var(--bg);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px 20px 64px;
	}

	.topbar {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 10px 0 24px;
	}

	.brand-row {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.brand {
		font-size: clamp(1.3rem, 2.2vw, 1.7rem);
		font-weight: 800;
		letter-spacing: 0.01em;
		color: var(--text);
	}

	.brand-r {
		color: #e3350d;
		font-size: 1.15em;
	}

	.menu-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		border: none;
		border-radius: 10px;
		background: transparent;
		color: var(--text);
		cursor: pointer;
	}

	.menu-toggle:hover {
		background: var(--bg-soft);
	}

	.sidebar-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.35);
		opacity: 0;
		transition: opacity 0.2s ease;
		z-index: 40;
	}

	.sidebar-overlay.open {
		opacity: 1;
	}

	.sidebar {
		position: fixed;
		top: 0;
		bottom: 0;
		left: 0;
		width: min(280px, 80vw);
		background: var(--card-bg);
		box-shadow: 4px 0 20px rgba(35, 35, 51, 0.15);
		transform: translateX(-100%);
		transition: transform 0.2s ease;
		z-index: 50;
		padding: 20px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		overflow-y: auto;
	}

	.sidebar.open {
		transform: translateX(0);
	}

	.sidebar-header {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		margin-bottom: 16px;
	}

	.sidebar-close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		padding: 0;
		border: none;
		border-radius: 8px;
		background: transparent;
		color: var(--text);
		cursor: pointer;
	}

	.sidebar-close:hover {
		background: var(--bg-soft);
	}

	.sidebar-account {
		margin-top: auto;
		padding-top: 16px;
		border-top: 1px solid var(--border);
	}

	.sidebar-account-name {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.sidebar-account-email {
		margin: 2px 0 10px;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.sidebar-account form {
		margin: 0;
	}

	.sidebar-logout {
		padding: 6px 12px;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text-muted);
		font-weight: 500;
		font-size: 0.85rem;
		cursor: pointer;
	}

	.sidebar-logout:hover {
		background: var(--bg-soft);
	}

	.sidebar-login {
		display: inline-flex;
		align-items: center;
		padding: 8px 14px;
		border-radius: 8px;
		border: 1px solid var(--border);
		color: var(--text);
		font-size: 0.88rem;
		font-weight: 600;
	}

	.sidebar-login:hover {
		background: var(--bg-soft);
	}

	.sidebar-about {
		margin: 0 0 16px;
		padding-bottom: 16px;
		border-bottom: 1px solid var(--border);
		font-size: 0.82rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.sidebar-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.sidebar-links a {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 8px;
		border-radius: 10px;
		color: var(--text);
		font-size: 0.9rem;
	}

	.sidebar-links a:hover {
		background: var(--bg-soft);
	}

	.sidebar-links svg {
		flex-shrink: 0;
		color: var(--text-muted);
	}

	.sidebar-link-text {
		display: flex;
		flex-direction: column;
		line-height: 1.3;
	}

	.sidebar-link-handle {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.sidebar-divider {
		height: 1px;
		margin: 8px 8px;
		background: var(--border);
	}

	.tab-nav {
		display: flex;
		gap: 4px;
		flex-wrap: wrap;
		border-bottom: 1px solid var(--border);
	}

	.nav-tab {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		color: var(--text-muted);
		border-bottom: 2px solid transparent;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.nav-tab:hover {
		color: var(--text);
		border-bottom-color: var(--border);
	}

	.nav-tab.current {
		color: var(--accent);
		border-bottom-color: var(--accent);
		font-weight: 700;
	}

	.mypage-tab.logged-in:not(.current) {
		color: var(--accent-dark);
	}

	.mypage-tab-wrap {
		position: relative;
		padding-bottom: 8px;
		margin-bottom: -8px;
	}

	.account-dropdown {
		position: absolute;
		top: 100%;
		right: 0;
		z-index: 60;
		min-width: 200px;
		padding: 14px;
		border-radius: var(--radius-md);
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
		opacity: 0;
		pointer-events: none;
		transform: translateY(-4px);
		transition: opacity 0.15s ease, transform 0.15s ease;
	}

	.mypage-tab-wrap:hover .account-dropdown,
	.mypage-tab-wrap:focus-within .account-dropdown {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}

	.dropdown-name {
		margin: 0;
		font-size: 0.92rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.dropdown-email {
		margin: 2px 0 10px;
		font-size: 0.8rem;
		color: var(--text-muted);
		white-space: nowrap;
	}

	.account-dropdown form {
		margin: 0;
	}

	.account-dropdown button {
		width: 100%;
		padding: 6px 10px;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text-muted);
		font-weight: 500;
		font-size: 0.85rem;
		cursor: pointer;
	}

	.account-dropdown button:hover {
		background: var(--bg-soft);
	}

	.page {
		padding-top: 12px;
	}

	@media (max-width: 720px) {
		.topbar {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
