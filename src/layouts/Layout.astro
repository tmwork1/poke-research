---
const {
	title = 'PokeResearch',
	description = 'ポケモンプログラミング情報ハブのローカル開発環境',
} = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<header class="topbar">
				<div>
					<a class="brand" href="/">PokeResearch</a>
				</div>
				<nav aria-label="Primary">
					<a class="home-link" href="/" aria-label="Top">
						<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M3 11l9-8 9 8" />
							<path d="M5 10v10h14V10" />
						</svg>
					</a>
				</nav>
			</header>
			<main class="page">
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	:global(:root) {
		color-scheme: light;
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;

		--bg: #f6f8fa;
		--bg-soft: #eef1f4;
		--card-bg: #ffffff;
		--border: #e3e7eb;
		--text: #232333;
		--text-muted: #6a737d;
		--accent: #1f9e7a;
		--accent-dark: #157a5e;
		--radius-lg: 20px;
		--radius-md: 14px;
		--shadow: 0 4px 16px rgba(35, 35, 51, 0.06);

		background: var(--bg);
		color: var(--text);
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		width: 100%;
	}

	body {
		background: var(--bg);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px 20px 64px;
	}

	.topbar {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 10px 0 24px;
	}

	.brand {
		font-size: clamp(1.3rem, 2.2vw, 1.7rem);
		font-weight: 800;
		letter-spacing: 0.01em;
		color: var(--text);
	}

	nav {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.home-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--card-bg);
		color: var(--text);
	}

	.home-link:hover {
		border-color: var(--accent);
		color: var(--accent-dark);
	}

	.page {
		padding-top: 12px;
	}

	@media (max-width: 720px) {
		.topbar {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
