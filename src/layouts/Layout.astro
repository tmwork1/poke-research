---
const {
	title = 'Pokemon Research Hub',
	description = 'ポケモンプログラミング情報ハブのローカル開発環境',
} = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<header class="topbar">
				<div>
					<p class="eyebrow">Information Hub</p>
					<a class="brand" href="/">Pokemon Research Hub</a>
				</div>
				<nav aria-label="Primary">
					<a href="/">Top</a>
					<a href="/items">Items</a>
					<a href="/search">Search</a>
				</nav>
			</header>
			<main class="page">
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	:global(:root) {
		color-scheme: dark;
		font-family: "Trebuchet MS", "Gill Sans", "Segoe UI", sans-serif;
		background:
			radial-gradient(circle at top left, rgba(111, 168, 255, 0.24), transparent 28%),
			radial-gradient(circle at 85% 12%, rgba(253, 212, 98, 0.22), transparent 24%),
			linear-gradient(180deg, #08111f 0%, #0d1729 42%, #101a2c 100%);
		color: #eef3ff;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		width: 100%;
	}

	body {
		background: transparent;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px 20px 64px;
	}

	.topbar {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 10px 0 24px;
	}

	.eyebrow {
		margin: 0 0 8px;
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(238, 243, 255, 0.7);
	}

	.brand {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.5rem, 2.5vw, 2.3rem);
		font-weight: 700;
		letter-spacing: 0.02em;
	}

	nav {
		display: flex;
		gap: 18px;
		flex-wrap: wrap;
	}

	nav a {
		padding: 10px 14px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(12px);
	}

	nav a:hover {
		border-color: rgba(255, 255, 255, 0.22);
		background: rgba(255, 255, 255, 0.09);
	}

	.page {
		padding-top: 12px;
	}

	@media (max-width: 720px) {
		.topbar {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
