---
import { topic } from '../config/topic.config.mjs';

const {
	title = topic.site.name,
	description = `${topic.collection.label}プログラミング情報ハブのローカル開発環境`,
	loggedIn = false,
	// SVG を無視するクローラー・SNS があるため、共有用画像は PNG を既定にする。
	ogImage = '/og-image.png',
	// クエリ違いの重複ページを正規化したい場合に、ページ側から明示的なパスを渡す。
	// 省略時は現在の pathname（クエリを含まない）をそのまま使う。
	canonicalPath,
	// 検索結果・ページングなど中身が薄い/重複しがちなページで true にする。
	noindex = false,
} = Astro.props;

const user = Astro.locals.user;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath ?? pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const shareText = topic.site.shareText;
const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(canonicalUrl.toString())}`;

// サイト全体の構造化データ。検索エンジンにサイト内検索(/items?q=)の存在も伝える。
const websiteJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: topic.site.name,
	description: topic.site.description,
	url: Astro.site?.toString(),
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: `${Astro.site?.toString().replace(/\/$/, '')}/items?q={search_term_string}`,
		},
		'query-input': 'required name=search_term_string',
	},
});
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<script is:inline define:vars={{ compactViewKey: `${topic.site.storageKeyPrefix}:compact-view` }}>
			(function () {
				try {
					if (localStorage.getItem(compactViewKey) === '1') {
						document.documentElement.classList.add('compact-view');
					}
				} catch (error) {
					// localStorageが使用できない環境では通常表示のままにする
				}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate" type="application/rss+xml" title={`${topic.site.name} 新着`} href="/rss.xml" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl.toString()} />
		{noindex && <meta name="robots" content="noindex, follow" />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl.toString()} />
		<meta property="og:image" content={ogImageUrl.toString()} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl.toString()} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={websiteJsonLd} />
	</head>
	<body>
		<div class="shell">
			<header class="topbar">
				<div class="brand-row">
					<button
						type="button"
						class="menu-toggle"
						aria-label="メニューを開く"
						aria-expanded="false"
						aria-controls="sidebar-panel"
						id="sidebar-toggle"
					>
						<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 6h16" />
							<path d="M4 12h16" />
							<path d="M4 18h16" />
						</svg>
					</button>
					<a class="brand" href="/">{topic.site.logoAccent.before}<span class="brand-r">{topic.site.logoAccent.accent}</span>{topic.site.logoAccent.after}</a>
				</div>
				<nav class="tab-nav" aria-label="Primary">
					<a class:list={['nav-tab', { current: pathname === '/' }]} href="/" aria-current={pathname === '/' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M3 11l9-8 9 8" />
							<path d="M5 10v10h14V10" />
						</svg>
						<span>ホーム</span>
					</a>
					<a class:list={['nav-tab', { current: pathname === '/items' }]} href="/items" aria-current={pathname === '/items' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M16 18l6-6-6-6" />
							<path d="M8 6l-6 6 6 6" />
							<path d="M9 20L15 4" />
						</svg>
						<span>記事</span>
					</a>
					<a class:list={['nav-tab', { current: pathname === '/papers' }]} href="/papers" aria-current={pathname === '/papers' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M6 3h9l4 4v14H6z" />
							<path d="M15 3v4h4" />
							<path d="M9 12h6" />
							<path d="M9 16h6" />
						</svg>
						<span>論文</span>
					</a>
					<a class:list={['nav-tab', { current: pathname === '/repos' }]} href="/repos" aria-current={pathname === '/repos' ? 'page' : undefined}>
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<polyline points="8 6 2 12 8 18" />
							<polyline points="16 6 22 12 16 18" />
						</svg>
						<span>リポジトリ</span>
					</a>
					{user ? (
						<a class:list={['nav-tab', 'mypage-tab', { current: pathname === '/mypage' }]} href="/mypage" aria-current={pathname === '/mypage' ? 'page' : undefined}>
							<span class="mypage-icon-wrap">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<circle cx="12" cy="8" r="4" />
									<path d="M4 20c0-4 3.5-7 8-7s8 3 8 7" />
								</svg>
								<span class="login-dot" aria-hidden="true" />
							</span>
							<span class="mypage-label-full">マイページ</span>
							<span class="mypage-label-short">マイ</span>
						</a>
					) : (
						<div class="mypage-tab-wrap">
							<a class:list={['nav-tab', 'mypage-tab', { current: pathname === '/mypage' }]} href="/mypage" aria-current={pathname === '/mypage' ? 'page' : undefined}>
								<span class="mypage-icon-wrap">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<circle cx="12" cy="8" r="4" />
										<path d="M4 20c0-4 3.5-7 8-7s8 3 8 7" />
									</svg>
								</span>
								<span class="mypage-label-full">マイページ</span>
								<span class="mypage-label-short">マイ</span>
							</a>
							{/* 未ログイン時のみ、タブ1回クリックでGoogleログインボタンをドロップダウンで直接出す
							    （ログイン中はドロップダウンを持たず、ログアウトはサイドバーに一本化） */}
							<div class="account-dropdown">
								<a class="dropdown-login-button" href="/api/auth/login">
									<svg width="16" height="16" viewBox="0 0 48 48" aria-hidden="true">
										<path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.5z" />
										<path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.9 18.9 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4c-7.7 0-14.3 4.4-17.7 10.7z" />
										<path fill="#4CAF50" d="M24 44c5.5 0 10.5-2.1 14.3-5.6l-6.6-5.6C29.6 34.6 26.9 36 24 36c-5.3 0-9.7-3.1-11.3-7.6l-6.5 5C9.6 39.5 16.2 44 24 44z" />
										<path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.6l6.6 5.6C41.5 36.6 44 30.8 44 24c0-1.3-.1-2.7-.4-3.5z" />
									</svg>
									<span>Google でログイン</span>
								</a>
							</div>
						</div>
					)}
				</nav>
			</header>
			<main class="page">
				<slot />
			</main>
		</div>
		<div class="sidebar-overlay" id="sidebar-overlay" hidden></div>
		<aside class="sidebar" id="sidebar-panel" aria-label="メニュー" inert>
			<div class="sidebar-header">
				<button type="button" class="sidebar-close" id="sidebar-close" aria-label="メニューを閉じる">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M6 6l12 12" />
						<path d="M18 6L6 18" />
					</svg>
				</button>
			</div>
			<ul class="sidebar-links">
				<li>
					<a href="/about">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="9" />
							<path d="M12 8h.01" />
							<path d="M11 12h1v4h1" />
						</svg>
						<span>このサイトについて</span>
					</a>
				</li>
				<li>
					<a href={shareUrl} target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="18" cy="5" r="3" />
							<circle cx="6" cy="12" r="3" />
							<circle cx="18" cy="19" r="3" />
							<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
							<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
						</svg>
						<span>このサイトを共有</span>
					</a>
				</li>
				<li>
					<a href={topic.site.contactUrl} target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 4h16v16H4z" opacity="0" />
							<path d="M22 5.5c-.8.4-1.6.6-2.5.7a4.3 4.3 0 0 0 1.9-2.4c-.9.5-1.8.9-2.8 1.1a4.2 4.2 0 0 0-7.3 3.8A12 12 0 0 1 2.9 4.3a4.2 4.2 0 0 0 1.3 5.6c-.7 0-1.4-.2-2-.5v.1a4.2 4.2 0 0 0 3.4 4.1c-.6.2-1.3.2-1.9.1a4.2 4.2 0 0 0 3.9 2.9A8.5 8.5 0 0 1 2 18.4a12 12 0 0 0 6.5 1.9c7.8 0 12-6.4 12-12v-.5c.8-.6 1.5-1.3 2-2.2z" fill="currentColor" stroke="none" />
						</svg>
						<span class="sidebar-link-text">
							<span>お問い合わせ</span>
							<span class="sidebar-link-handle">{topic.site.contactHandle}</span>
						</span>
					</a>
				</li>
				<li>
					<a href={topic.site.repoUrl} target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
							<path fill="currentColor" d="M12 2C6.48 2 2 6.58 2 12.17c0 4.47 2.87 8.26 6.84 9.6.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.72-2.78.62-3.37-1.36-3.37-1.36-.45-1.18-1.11-1.49-1.11-1.49-.91-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.17C22 6.58 17.52 2 12 2z" />
						</svg>
						<span>GitHub リポジトリ</span>
					</a>
				</li>
				<li class="sidebar-divider" role="separator"></li>
				<li>
					<a href="/api/export/items.csv">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 3v12" />
							<path d="M7 10l5 5 5-5" />
							<path d="M4 19h16" />
						</svg>
						<span>CSV 出力</span>
					</a>
				</li>
				<li>
					<a href="/rss.xml">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M4 11a9 9 0 0 1 9 9" />
							<path d="M4 4a16 16 0 0 1 16 16" />
							<circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
						</svg>
						<span>RSS 購読</span>
					</a>
				</li>
			</ul>
			<div class="sidebar-account">
				{user ? (
					<>
						<p class="sidebar-account-name">{user.displayName ?? user.email ?? 'ログイン中'}</p>
						{user.email ? <p class="sidebar-account-email">{user.email}</p> : null}
						<form method="post" action="/api/auth/logout">
							<button type="submit" class="sidebar-logout">ログアウト</button>
						</form>
					</>
				) : (
					<a class="sidebar-login" href="/api/auth/login">Google でログイン</a>
				)}
			</div>
		</aside>
	</body>
</html>

<script>
	const toggle = document.getElementById('sidebar-toggle');
	const closeBtn = document.getElementById('sidebar-close');
	const overlay = document.getElementById('sidebar-overlay');
	const sidebar = document.getElementById('sidebar-panel');

	function openSidebar() {
		sidebar?.classList.add('open');
		sidebar?.removeAttribute('inert');
		overlay?.removeAttribute('hidden');
		requestAnimationFrame(() => overlay?.classList.add('open'));
		toggle?.setAttribute('aria-expanded', 'true');
		closeBtn?.focus();
	}

	function closeSidebar() {
		const wasOpen = sidebar?.classList.contains('open');
		sidebar?.classList.remove('open');
		sidebar?.setAttribute('inert', '');
		overlay?.classList.remove('open');
		toggle?.setAttribute('aria-expanded', 'false');
		setTimeout(() => overlay?.setAttribute('hidden', ''), 200);
		if (wasOpen) {
			toggle?.focus();
		}
	}

	toggle?.addEventListener('click', () => {
		const isOpen = sidebar?.classList.contains('open');
		if (isOpen) {
			closeSidebar();
		} else {
			openSidebar();
		}
	});

	closeBtn?.addEventListener('click', closeSidebar);
	overlay?.addEventListener('click', closeSidebar);

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && sidebar?.classList.contains('open')) {
			closeSidebar();
		}
	});

	// 未ログイン時のみ、タブクリックでGoogleログインボタンのドロップダウンを開閉する
	// （ログイン中はこの要素自体が存在しないため何もしない）。
	const mypageTabWrap = document.querySelector('.mypage-tab-wrap');

	function closeMypageDropdown() {
		mypageTabWrap?.classList.remove('open');
	}

	mypageTabWrap?.addEventListener('click', (event) => {
		if (!(event.target instanceof Element) || !event.target.closest('.mypage-tab')) return;
		event.preventDefault();
		mypageTabWrap.classList.toggle('open');
	});

	if (mypageTabWrap) {
		document.addEventListener('click', (event) => {
			if (event.target instanceof Node && !mypageTabWrap.contains(event.target)) {
				closeMypageDropdown();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeMypageDropdown();
		});
	}
</script>

<style>
	:global(:root) {
		color-scheme: light dark;
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;

		--bg: #f6f8fa;
		--bg-soft: #eef1f4;
		--card-bg: #ffffff;
		--border: #e3e7eb;
		--text: #232333;
		--text-muted: #6a737d;
		--accent: #1f9e7a;
		--accent-dark: #157a5e;
		--mark-bg: #fff3bf;
		--radius-lg: 20px;
		--radius-md: 14px;
		--shadow: 0 4px 16px rgba(35, 35, 51, 0.06);

		background: var(--bg);
		color: var(--text);
	}

	@media (prefers-color-scheme: dark) {
		:global(:root) {
			--bg: #16181d;
			--bg-soft: #1b1e24;
			--card-bg: #1e2128;
			--border: #33373f;
			--text: #e6e6eb;
			--text-muted: #9a9ea6;
			--accent: #33b992;
			--accent-dark: #5fd1ac;
			--mark-bg: #5c4d1a;
			--shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
		}
	}

	html {
		/* タグ解説ポップオーバーの開閉でページの縦スクロールバーが出たり消えたりすると、
		   本文全体が横に数px動いてホバー中の要素がカーソル下から外れてしまう（ホバー解除→
		   ポップオーバーが閉じる→再度ホバーが入る、を繰り返すちらつきの原因になる）。
		   スクロールバー分の余白を常に確保して、この横シフトを防ぐ。 */
		scrollbar-gutter: stable;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		width: 100%;
	}

	body {
		background: var(--bg);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px 20px 64px;
	}

	.topbar {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		padding: 10px 0 24px;
	}

	.brand-row {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.brand {
		font-size: clamp(1.3rem, 2.2vw, 1.7rem);
		font-weight: 800;
		letter-spacing: 0.01em;
		color: var(--text);
	}

	.brand-r {
		color: #e3350d;
		font-size: 1.15em;
	}

	.menu-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		border: none;
		border-radius: 10px;
		background: transparent;
		color: var(--text);
		cursor: pointer;
	}

	.menu-toggle:hover {
		background: var(--bg-soft);
	}

	.sidebar-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.35);
		opacity: 0;
		transition: opacity 0.2s ease;
		z-index: 40;
	}

	.sidebar-overlay.open {
		opacity: 1;
	}

	.sidebar {
		position: fixed;
		top: 0;
		bottom: 0;
		left: 0;
		width: min(280px, 80vw);
		background: var(--card-bg);
		box-shadow: 4px 0 20px rgba(35, 35, 51, 0.15);
		transform: translateX(-100%);
		transition: transform 0.2s ease;
		z-index: 50;
		padding: 20px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		overflow-y: auto;
	}

	.sidebar.open {
		transform: translateX(0);
	}

	.sidebar-header {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		margin-bottom: 16px;
	}

	.sidebar-close {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		padding: 0;
		border: none;
		border-radius: 8px;
		background: transparent;
		color: var(--text);
		cursor: pointer;
	}

	.sidebar-close:hover {
		background: var(--bg-soft);
	}

	.sidebar-account {
		margin-top: auto;
		/* .sidebar-links a の左右パディング(8px)に揃え、ナビ項目と同じ位置から始まるようにする */
		padding: 16px 8px 8px;
		border-top: 1px solid var(--border);
	}

	.sidebar-account-name {
		margin: 0;
