---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CatalogPage from '../../components/CatalogPage.astro';
import { fetchBookmarkCounts, fetchBookmarkedItemIds, fetchCatalogItemsPage, fetchCatalogSources, fetchTopTags } from '../../lib/catalog';
import { parseOptionalPositiveInteger } from '../../lib/params';

const url = new URL(Astro.request.url);
const sourceIds = url.searchParams
	.getAll('sourceId')
	.map((value) => parseOptionalPositiveInteger(value))
	.filter((value): value is number => value !== undefined);
const sortParam = url.searchParams.get('sort');
const sort = sortParam === 'popular' ? 'popular' : sortParam === 'oldest' ? 'oldest' : 'new';
const filters = {
	q: url.searchParams.get('q') ?? '',
	tag: url.searchParams.get('tag') ?? '',
	sourceIds,
	sort,
};
const page = parseOptionalPositiveInteger(url.searchParams.get('page')) ?? 1;

const user = Astro.locals.user;

const [itemsPage, topTags, sources, bookmarkedItemIds] = await Promise.all([
	fetchCatalogItemsPage({
		q: filters.q || undefined,
		tag: filters.tag || undefined,
		sourceIds: filters.sourceIds.length > 0 ? filters.sourceIds : undefined,
		sort: filters.sort,
		page,
	}),
	fetchTopTags(20),
	fetchCatalogSources(),
	user ? fetchBookmarkedItemIds(user.id) : Promise.resolve(new Set<number>()),
]);
const bookmarkCounts = await fetchBookmarkCounts(itemsPage.items.map((item) => item.id));
---

<Layout title="Items | PokeResearch" description="アイテム一覧・検索画面" loggedIn={Boolean(user)}>
	<CatalogPage
		title="アイテム一覧・検索"
		eyebrow="Search items"
		basePath="/items"
		items={itemsPage.items}
		topTags={topTags}
		sources={sources}
		filters={filters}
		pagination={{ page: itemsPage.page, totalPages: itemsPage.totalPages, total: itemsPage.total }}
		bookmarkedItemIds={bookmarkedItemIds}
		bookmarkCounts={bookmarkCounts}
		loggedIn={Boolean(user)}
	/>
</Layout>
