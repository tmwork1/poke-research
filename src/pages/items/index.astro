---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CatalogPage from '../../components/CatalogPage.astro';
import { fetchCatalogItemsPage, fetchCatalogSources, fetchTopTags } from '../../lib/catalog';
import { parseOptionalPositiveInteger } from '../../lib/params';

const url = new URL(Astro.request.url);
const filters = {
	q: url.searchParams.get('q') ?? '',
	tag: url.searchParams.get('tag') ?? '',
	sourceId: url.searchParams.get('sourceId') ?? '',
};
const page = parseOptionalPositiveInteger(url.searchParams.get('page')) ?? 1;

const [itemsPage, topTags, sources] = await Promise.all([
	fetchCatalogItemsPage({
		q: filters.q || undefined,
		tag: filters.tag || undefined,
		sourceId: parseOptionalPositiveInteger(filters.sourceId),
		page,
	}),
	fetchTopTags(20),
	fetchCatalogSources(),
]);
---

<Layout title="Items | PokeResearch" description="アイテム一覧・検索画面">
	<CatalogPage
		title="アイテム一覧・検索"
		eyebrow="Search items"
		basePath="/items"
		items={itemsPage.items}
		topTags={topTags}
		sources={sources}
		filters={filters}
		pagination={{ page: itemsPage.page, totalPages: itemsPage.totalPages, total: itemsPage.total }}
	/>
</Layout>
