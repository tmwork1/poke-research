---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CatalogPage from '../../components/CatalogPage.astro';
import { fetchCatalogItems, fetchCatalogSources, fetchCatalogTags } from '../../lib/catalog';

const url = new URL(Astro.request.url);
const filters = {
	q: url.searchParams.get('q') ?? '',
	kind: url.searchParams.get('kind') ?? '',
	tag: url.searchParams.get('tag') ?? '',
	sourceId: url.searchParams.get('sourceId') ?? '',
};

const [items, tags, sources] = await Promise.all([
	fetchCatalogItems({
		q: filters.q || undefined,
		kind: filters.kind || undefined,
		tag: filters.tag || undefined,
		sourceId: filters.sourceId ? Number(filters.sourceId) : undefined,
	}),
	fetchCatalogTags(),
	fetchCatalogSources(),
]);
---

<Layout title="Items | Pokemon Research Hub" description="アイテム一覧とフィルタ画面">
	<CatalogPage
		title="アイテム一覧"
		lead="キーワード、種別、タグ、公開元で絞り込みながら、各アイテムの詳細へ移動できます。"
		basePath="/items"
		items={items}
		tags={tags}
		sources={sources}
		filters={filters}
	/>
</Layout>