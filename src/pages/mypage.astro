---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import ItemCard from '../components/ItemCard.astro';
import SortSelect from '../components/SortSelect.astro';
import TagCloud from '../components/TagCloud.astro';
import CompactToggle from '../components/CompactToggle.astro';
import { fetchBookmarkCounts, fetchBookmarkedItemsFiltered, fetchRecommendedItems, type CatalogItem, type CatalogSort, type TagUsage } from '../lib/catalog';

const user = Astro.locals.user;
const url = new URL(Astro.request.url);
const bookmarkTag = url.searchParams.get('bookmarkTag') ?? '';
const bookmarkSortParam = url.searchParams.get('bookmarkSort');
const bookmarkSort: CatalogSort =
	bookmarkSortParam === 'oldest' || bookmarkSortParam === 'popular' ? bookmarkSortParam : 'new';

function buildBookmarkUrl(overrides: { tag: string }) {
	const params = new URLSearchParams();
	if (overrides.tag) params.set('bookmarkTag', overrides.tag);
	if (bookmarkSort !== 'new') params.set('bookmarkSort', bookmarkSort);
	const qs = params.toString();
	return qs ? `/mypage?${qs}` : '/mypage';
}

let bookmarkedItems: CatalogItem[] = [];
let bookmarkTagOptions: TagUsage[] = [];
let hasBookmarks = false;
let recommendedItems: CatalogItem[] = [];
let bookmarkCounts = new Map<number, number>();
let loadError = false;
if (user) {
	try {
		const [bookmarked, recommended] = await Promise.all([
			fetchBookmarkedItemsFiltered(user.id, { tag: bookmarkTag || undefined, sort: bookmarkSort }),
			fetchRecommendedItems(user.id),
		]);
		bookmarkedItems = bookmarked.items;
		bookmarkTagOptions = bookmarked.availableTags;
		hasBookmarks = bookmarked.total > 0;
		recommendedItems = recommended;
		bookmarkCounts = await fetchBookmarkCounts([...bookmarkedItems, ...recommendedItems].map((item) => item.id));
	} catch (error) {
		console.error('Failed to load bookmarks:', error);
		loadError = true;
	}
}
---

<Layout title="マイページ | PokeResearch" description="ログインとお気に入りの管理" loggedIn={Boolean(user)}>
	{user ? (
		<section class="mypage">
			<div class="eyebrow-row">
				<p class="eyebrow">Bookmarks</p>
				<CompactToggle />
			</div>
			<section class="panel">
				{loadError ? (
					<div class="empty" role="alert">お気に入りの取得に失敗しました。しばらくしてから再度お試しください。</div>
				) : hasBookmarks ? (
					<>
						<div class="tag-filter">
							<TagCloud topTags={bookmarkTagOptions} activeTags={bookmarkTag ? [bookmarkTag] : []} buildTagsUrl={(tags) => buildBookmarkUrl({ tag: tags[tags.length - 1] ?? '' })} />
						</div>
						<form class="sort-row" method="get" action="/mypage">
							<input type="hidden" name="bookmarkTag" value={bookmarkTag} />
							<SortSelect
								name="bookmarkSort"
								ariaLabel="並び替え"
								options={[
									{ value: 'new', label: '新着順', selected: bookmarkSort === 'new' },
									{ value: 'popular', label: '人気順', selected: bookmarkSort === 'popular' },
									{ value: 'oldest', label: '古い順', selected: bookmarkSort === 'oldest' },
								]}
							/>
						</form>
						{bookmarkedItems.length > 0 ? (
							<div class="cards">
								{bookmarkedItems.map((item) => <ItemCard item={item} bookmarked loggedIn bookmarkCount={bookmarkCounts.get(item.id) ?? 0} />)}
							</div>
						) : (
							<div class="empty">条件に一致するお気に入りがありません。</div>
						)}
					</>
				) : (
					<div class="empty">お気に入りはまだありません。<a href="/items">一覧</a>からアイテムを追加できます。</div>
				)}
			</section>

			{!loadError && recommendedItems.length > 0 ? (
				<>
					<div class="eyebrow-row">
						<p class="eyebrow">Recommended for you</p>
						<CompactToggle />
					</div>
					<section class="panel">
						<div class="cards">
							{recommendedItems.map((item) => <ItemCard item={item} loggedIn bookmarkCount={bookmarkCounts.get(item.id) ?? 0} />)}
						</div>
					</section>
				</>
			) : null}
		</section>
	) : (
		<section class="login-panel">
			<p class="eyebrow">My page</p>
			<p class="login-desc">Google アカウントでログインすると、お気に入り機能が使えます。</p>
			<a class="google-login-button" href="/api/auth/login">
				<svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
					<path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.5z" />
					<path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.9 18.9 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4c-7.7 0-14.3 4.4-17.7 10.7z" />
					<path fill="#4CAF50" d="M24 44c5.5 0 10.5-2.1 14.3-5.6l-6.6-5.6C29.6 34.6 26.9 36 24 36c-5.3 0-9.7-3.1-11.3-7.6l-6.5 5C9.6 39.5 16.2 44 24 44z" />
					<path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.6l6.6 5.6C41.5 36.6 44 30.8 44 24c0-1.3-.1-2.7-.4-3.5z" />
				</svg>
				<span>Google でログイン</span>
			</a>
		</section>
	)}
</Layout>

<style>
	.mypage {
		display: grid;
		gap: 24px;
	}

	.eyebrow-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin: 0 0 4px;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.panel,
	.empty {
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.panel {
		display: grid;
		gap: 20px;
		padding: 24px;
		border-radius: var(--radius-lg);
	}

	.sort-row {
		display: flex;
		justify-content: flex-start;
	}

	.cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 18px;
	}

	.empty {
		padding: 20px;
		border-radius: var(--radius-md);
	}

	.login-panel {
		display: grid;
		gap: 14px;
		max-width: 480px;
		padding: 32px;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.login-panel .login-desc {
		margin: 0;
		color: var(--text-muted);
	}

	.google-login-button {
		justify-self: start;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 20px 10px 14px;
		border-radius: 8px;
		border: 1px solid #dadce0;
		background: #fff;
		color: #3c4043;
		font-weight: 500;
		font-size: 0.95rem;
		box-shadow: 0 1px 2px rgba(60, 64, 67, 0.15);
	}

	.google-login-button:hover {
		background: #f8f9fa;
		box-shadow: 0 1px 3px rgba(60, 64, 67, 0.25);
	}

</style>

