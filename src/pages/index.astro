---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { fetchCatalogOverview } from '../lib/catalog';

const overview = await fetchCatalogOverview();

const metrics = [
	{ label: 'Items', value: overview.items.length },
	{ label: 'Tags', value: overview.tags.length },
	{ label: 'Sources', value: overview.sources.length },
	{ label: 'Annotations', value: overview.annotations.length },
];
---

<Layout title="Pokemon Research Hub" description="ポケモンプログラミング情報ハブのトップページ">
	<section class="home">
		<header class="hero">
			<div>
				<p class="eyebrow">M2 Search and UI</p>
				<h1>知見を集め、探し、たどれるローカル情報ハブ。</h1>
				<p>
					ソース、アイテム、注釈、タグをひとつの導線にまとめ、検索と詳細確認をそのまま往復できるようにしました。
				</p>
			</div>
			<div class="hero-links">
				<a href="/items">一覧を見る</a>
				<a href="/search">検索する</a>
			</div>
		</header>

		<section class="metrics" aria-label="Catalog metrics">
			{metrics.map((metric) => (
				<div>
					<strong>{metric.value}</strong>
					<span>{metric.label}</span>
				</div>
			))}
		</section>

		<section class="panel">
			<div class="section-head">
				<div>
					<p class="eyebrow">Recent items</p>
					<h2>最近追加されたアイテム</h2>
				</div>
				<a href="/items">すべて見る</a>
			</div>
			<div class="cards">
				{overview.items.length > 0 ? overview.items.map((item) => (
					<article class="card">
						<p class="kind">{item.kind || 'untyped'}</p>
						<a class="title" href={`/items/${item.id}`}>{item.title || `Item ${item.id}`}</a>
						<p>{item.summary || '要約はまだ登録されていません。'}</p>
						<div class="meta">
							<span>{item.source?.name || '未設定の出典'}</span>
							<span>{item.tags.map((tag) => `#${tag.name}`).join(' ') || 'タグなし'}</span>
						</div>
					</article>
				)) : (
					<div class="empty">まだアイテムがありません。 scripts/seed-sample-article.mjs でサンプルを投入できます。</div>
				)}
			</div>
		</section>

		<section class="panel split">
			<div>
				<p class="eyebrow">Shortcuts</p>
				<h2>主要画面</h2>
				<ul>
					<li><a href="/items">一覧画面</a></li>
					<li><a href="/search">検索結果画面</a></li>
					<li><a href="/api/items">API items</a></li>
					<li><a href="/api/tags">API tags</a></li>
				</ul>
			</div>
			<div>
				<p class="eyebrow">Next step</p>
				<h2>検索条件の確認</h2>
				<p>
					キーワード、種別、タグ、公開元を組み合わせて、ローカルデータの探索動線をそのまま検証できます。
				</p>
			</div>
		</section>
	</section>
</Layout>

<style>
	.home {
		display: grid;
		gap: 24px;
	}

	.hero,
	.panel,
	.metrics div,
	.card,
	.empty {
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(8, 15, 29, 0.72);
		backdrop-filter: blur(16px);
		box-shadow: 0 20px 45px rgba(0, 0, 0, 0.22);
	}

	.hero {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		padding: 30px;
		border-radius: 28px;
	}

	.hero h1,
	h2 {
		font-family: Georgia, "Times New Roman", serif;
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.8rem);
		line-height: 1.1;
	}

	.hero p {
		max-width: 62ch;
		line-height: 1.75;
		color: rgba(238, 243, 255, 0.82);
	}

	.eyebrow {
		margin: 0 0 10px;
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(238, 243, 255, 0.72);
	}

	.hero-links {
		display: flex;
		flex-direction: column;
		justify-content: end;
		gap: 12px;
	}

	.hero-links a,
	.section-head a {
		padding: 12px 16px;
		border-radius: 14px;
		background: linear-gradient(135deg, #f3cf72 0%, #f08c68 100%);
		color: #111827;
		font-weight: 700;
		text-align: center;
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 16px;
	}

	.metrics div {
		padding: 18px;
		border-radius: 20px;
		text-align: center;
	}

	.metrics strong {
		display: block;
		font-size: 2rem;
	}

	.metrics span {
		color: rgba(238, 243, 255, 0.72);
	}

	.panel {
		padding: 24px;
		border-radius: 26px;
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		margin-bottom: 18px;
	}

	.section-head h2 {
		margin: 0;
		font-size: 1.9rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.card,
	.empty {
		padding: 20px;
		border-radius: 20px;
	}

	.card p {
		color: rgba(238, 243, 255, 0.82);
		line-height: 1.7;
	}

	.kind {
		margin: 0 0 8px;
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #f3cf72;
	}

	.title {
		display: inline-block;
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.35;
	}

	.meta {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		font-size: 0.9rem;
		color: rgba(238, 243, 255, 0.72);
	}

	.split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 24px;
	}

	.split ul {
		margin: 0;
		padding-left: 18px;
		line-height: 1.8;
	}

	@media (max-width: 960px) {
		.hero,
		.cards,
		.metrics,
		.split {
			grid-template-columns: 1fr;
		}

		.hero {
			flex-direction: column;
		}
	}
</style>
