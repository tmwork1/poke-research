---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import ItemCard from '../components/ItemCard.astro';
import ItemListJsonLd from '../components/ItemListJsonLd.astro';
import SortSelect from '../components/SortSelect.astro';
import TagCloud from '../components/TagCloud.astro';
import TagTrendChart from '../components/TagTrendChart.astro';
import CompactToggle from '../components/CompactToggle.astro';
import { fetchBookmarkedItemIds, fetchCatalogItemsPage, fetchTagTrend, fetchTopTags, type CatalogItem, type CatalogSort } from '../lib/catalog';
import { parseOptionalPositiveInteger } from '../lib/params';
import { topic } from '../config/topic.config.mjs';

const PAGE_SIZE = 12;

const user = Astro.locals.user;
const url = new URL(Astro.request.url);
const activeTag = url.searchParams.get('tag') ?? '';
const activeSort: CatalogSort = url.searchParams.get('sort') === 'popular' ? 'popular' : 'new';
const page = parseOptionalPositiveInteger(url.searchParams.get('page')) ?? 1;
// トップページはタグ/並び替え/ページングの組み合わせで内容が変わるため、
// クエリ付きの表示は noindex にし、canonical は常に / へ寄せる。
const noindex = url.searchParams.has('tag') || url.searchParams.has('sort') || url.searchParams.has('page');

function buildUrl(overrides: { tag: string }) {
	const params = new URLSearchParams();
	if (overrides.tag) params.set('tag', overrides.tag);
	if (activeSort !== 'new') params.set('sort', activeSort);
	const qs = params.toString();
	return qs ? `/?${qs}` : '/';
}

let recentItems: CatalogItem[];
let bookmarkedItemIds = new Set<number>();
let loadError = false;
let hasMore = false;
const topTags = await fetchTopTags(5);
const tagTrend = await fetchTagTrend(topTags);
try {
	const [itemsPage, bookmarks] = await Promise.all([
		fetchCatalogItemsPage({ tag: activeTag || undefined, sort: activeSort, page, pageSize: PAGE_SIZE }),
		user ? fetchBookmarkedItemIds(user.id) : Promise.resolve(new Set<number>()),
	]);
	recentItems = itemsPage.items;
	hasMore = itemsPage.page < itemsPage.totalPages;
	bookmarkedItemIds = bookmarks;
} catch (error) {
	console.error('Failed to load recent items:', error);
	loadError = true;
	recentItems = [];
}
---

<Layout
	title={topic.site.name}
	description={`${topic.collection.label}プログラミング情報ハブのトップページ`}
	loggedIn={Boolean(user)}
	canonicalPath="/"
	noindex={noindex}
>
	<section class="home">
		<ItemListJsonLd items={recentItems} />
		{loadError && (
			<div class="empty" role="alert">
				データの取得に失敗しました。しばらくしてから再度お試しください。
			</div>
		)}
		<div class="eyebrow-row">
			<p class="eyebrow">Recent items</p>
			<CompactToggle />
		</div>
		<section class="panel">
			<div class="tag-filter">
				<TagCloud topTags={topTags} activeTags={activeTag ? [activeTag] : []} buildTagsUrl={(tags) => buildUrl({ tag: tags[tags.length - 1] ?? '' })} />
			</div>
			<form class="sort-row" method="get" action="/">
				<input type="hidden" name="tag" value={activeTag} />
				<SortSelect
					name="sort"
					ariaLabel="並び順"
					options={[
						{ value: 'new', label: '新着順', selected: activeSort !== 'popular' },
						{ value: 'popular', label: '人気順', selected: activeSort === 'popular' },
					]}
				/>
				{topTags.length > 0 && <TagTrendChart trend={tagTrend} />}
			</form>
			{page > 1 && (
				<p class="resume-notice">
					記事リンクの遷移前後で表示位置を保つため、途中のページから表示しています。
					<a href={buildUrl({ tag: activeTag })}>1ページ目から表示</a>
				</p>
			)}
			<div class="cards" data-page={page} data-has-more={hasMore ? 'true' : 'false'} data-tag={activeTag} data-sort={activeSort}>
				{recentItems.length > 0 ? recentItems.map((item) => (
					<ItemCard item={item} bookmarked={bookmarkedItemIds.has(item.id)} bookmarkCount={item.bookmarks_count ?? 0} loggedIn={Boolean(user)} />
				)) : activeTag ? (
					<div class="empty">
						このタグの記事はまだありません。<br />
						<a href={buildUrl({ tag: '' })}>すべての記事を見る</a>
					</div>
				) : (
					<div class="empty">記事を準備中です。しばらくしてからご覧ください。</div>
				)}
			</div>
			<div class="loading-skeleton" hidden aria-hidden="true">
				<div class="skeleton-card">
					<div class="skeleton-line skeleton-title"></div>
					<div class="skeleton-line skeleton-summary"></div>
					<div class="skeleton-line skeleton-summary short"></div>
					<div class="skeleton-tags">
						<span class="skeleton-tag"></span>
						<span class="skeleton-tag"></span>
					</div>
				</div>
				<div class="skeleton-card">
					<div class="skeleton-line skeleton-title"></div>
					<div class="skeleton-line skeleton-summary"></div>
					<div class="skeleton-line skeleton-summary short"></div>
					<div class="skeleton-tags">
						<span class="skeleton-tag"></span>
						<span class="skeleton-tag"></span>
					</div>
				</div>
			</div>
			<p class="sr-only" role="status" aria-live="polite"></p>
		</section>
	</section>
</Layout>

<style>
	.home {
		display: grid;
		gap: 24px;
	}

	.empty {
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.eyebrow-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin: 0 0 10px;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.tag-filter {
		margin-bottom: 16px;
	}

	.sort-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 16px;
	}

	.cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 16px;
	}

	.empty {
		padding: 20px;
		border-radius: var(--radius-md);
	}

	.empty a {
		color: var(--accent-dark);
	}

	.resume-notice {
		margin: 0 0 16px;
		padding: 10px 14px;
		border-radius: var(--radius-md);
		background: var(--bg-soft);
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	.resume-notice a {
		margin-left: 6px;
		color: var(--accent-dark);
		font-weight: 600;
	}

	/* aria-live での読み上げ専用。視覚的には非表示にする（CompactToggle と同じクリップ手法）。 */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.loading-skeleton {
		display: grid;
		grid-template-columns: 1fr;
		gap: 16px;
		margin-top: 16px;
	}

	.skeleton-card {
		display: grid;
		gap: 14px;
		padding: 22px;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.skeleton-line {
		height: 14px;
		border-radius: 999px;
		background: var(--bg-soft);
		animation: skeleton-pulse 1.4s ease-in-out infinite;
	}

	.skeleton-title {
		width: 55%;
		height: 20px;
	}

	.skeleton-summary {
		width: 100%;
	}

	.skeleton-summary.short {
		width: 70%;
	}

	.skeleton-tags {
		display: flex;
		gap: 8px;
	}

	.skeleton-tag {
		width: 64px;
		height: 24px;
		border-radius: 999px;
		background: var(--bg-soft);
		animation: skeleton-pulse 1.4s ease-in-out infinite;
	}

	@keyframes skeleton-pulse {
		0%,
		100% {
			opacity: 0.6;
		}
		50% {
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.skeleton-line,
		.skeleton-tag {
			animation: none;
		}
	}

</style>

<script>
	const cardsEl = document.querySelector<HTMLDivElement>('.cards[data-page]');
	const loadingSkeleton = document.querySelector<HTMLElement>('.loading-skeleton');
	const statusEl = document.querySelector<HTMLElement>('.sr-only[role="status"]');

	if (cardsEl) {
		let page = Number(cardsEl.dataset.page ?? '1');
		let hasMore = cardsEl.dataset.hasMore === 'true';
		let loading = false;
		const tag = cardsEl.dataset.tag ?? '';
		const sort = cardsEl.dataset.sort ?? 'new';

		const sentinel = document.createElement('div');
		sentinel.setAttribute('aria-hidden', 'true');
		cardsEl.insertAdjacentElement('afterend', sentinel);

		// 追加読み込みのたびに URL の page をこの位置に更新する。記事リンクから「戻る」で戻った際に、
		// 直前までスクロールしていた位置に近いページ番号がアドレスバーに残るようにするため。
		function syncUrl() {
			const params = new URLSearchParams();
			if (tag) params.set('tag', tag);
			if (sort !== 'new') params.set('sort', sort);
			if (page > 1) params.set('page', String(page));
			const qs = params.toString();
			history.replaceState(null, '', qs ? `/?${qs}` : '/');
		}

		const observer = new IntersectionObserver(async (entries) => {
			if (!hasMore || loading || !entries.some((entry) => entry.isIntersecting)) return;
			loading = true;
			loadingSkeleton?.removeAttribute('hidden');

			const nextPage = page + 1;
			const params = new URLSearchParams();
			if (tag) params.set('tag', tag);
			if (sort !== 'new') params.set('sort', sort);
			params.set('page', String(nextPage));

			try {
				const response = await fetch(`/?${params.toString()}`);
				if (!response.ok) throw new Error(`failed to load more items: ${response.status}`);
				const html = await response.text();
				const nextCards = new DOMParser().parseFromString(html, 'text/html').querySelector('.cards[data-page]');
				if (nextCards) {
					const addedCount = nextCards.children.length;
					cardsEl.append(...nextCards.children);
					page = Number(nextCards.getAttribute('data-page') ?? String(nextPage));
					hasMore = nextCards.getAttribute('data-has-more') === 'true';
					syncUrl();
					if (statusEl) statusEl.textContent = `${addedCount}件追加されました`;
				} else {
					hasMore = false;
				}
			} catch (error) {
				console.error('Failed to load more items:', error);
			} finally {
				loading = false;
				loadingSkeleton?.setAttribute('hidden', '');
				if (!hasMore) observer.disconnect();
			}
		}, { rootMargin: '400px' });

		observer.observe(sentinel);
	}
</script>
