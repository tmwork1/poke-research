---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import ItemCard from '../components/ItemCard.astro';
import { fetchBookmarkedItemIds, fetchCatalogItems, type CatalogItem } from '../lib/catalog';

const user = Astro.locals.user;

let recentItems: CatalogItem[];
let bookmarkedItemIds = new Set<number>();
let loadError = false;
try {
	[recentItems, bookmarkedItemIds] = await Promise.all([
		fetchCatalogItems({ limit: 6 }),
		user ? fetchBookmarkedItemIds(user.id) : Promise.resolve(new Set<number>()),
	]);
} catch (error) {
	console.error('Failed to load recent items:', error);
	loadError = true;
	recentItems = [];
}
---

<Layout title="PokeResearch" description="ポケモンプログラミング情報ハブのトップページ">
	<section class="home">
		{loadError && (
			<div class="empty" role="alert">
				データの取得に失敗しました。しばらくしてから再度お試しください。
			</div>
		)}
		<section class="panel">
			<div class="section-head">
				<div>
					<p class="eyebrow">Recent items</p>
					<h2>最近追加されたアイテム</h2>
				</div>
				<a href="/items">すべて見る</a>
			</div>
			<div class="cards">
				{recentItems.length > 0 ? recentItems.map((item) => <ItemCard item={item} bookmarked={bookmarkedItemIds.has(item.id)} loggedIn={Boolean(user)} />) : (
					<div class="empty">まだアイテムがありません。 scripts/db/seed-sample-article.mjs でサンプルを投入できます。</div>
				)}
			</div>
		</section>
	</section>
</Layout>

<style>
	.home {
		display: grid;
		gap: 24px;
	}

	.panel,
	.empty {
		border: 1px solid var(--border);
		background: var(--card-bg);
		box-shadow: var(--shadow);
	}

	.eyebrow {
		margin: 0 0 10px;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.section-head a {
		padding: 12px 16px;
		border-radius: 12px;
		background: var(--accent);
		color: #fff;
		font-weight: 700;
		text-align: center;
	}

	.panel {
		padding: 24px;
		border-radius: var(--radius-lg);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		margin-bottom: 18px;
	}

	.section-head h2 {
		margin: 0;
		font-size: 1.6rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.empty {
		padding: 20px;
		border-radius: var(--radius-md);
	}

	@media (max-width: 960px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
