---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CatalogPage from '../../components/CatalogPage.astro';
import ItemCard from '../../components/ItemCard.astro';
import {
	fetchBookmarkedItemIds,
	fetchCatalogItemsPage,
	fetchCatalogSources,
	fetchRelatedItems,
	fetchTopTags,
	resolveItemIdsByTag,
	type CatalogItem,
} from '../../lib/catalog';
import { parseOptionalPositiveInteger } from '../../lib/params';
import { formatTagLabel } from '../../lib/tag-display';
import { topic } from '../../config/topic.config.mjs';

const tagName = decodeURIComponent(Astro.params.name ?? '');
const tagLabel = formatTagLabel(tagName);
const url = new URL(Astro.request.url);
const page = parseOptionalPositiveInteger(url.searchParams.get('page')) ?? 1;
const canonicalPath = `/tags/${encodeURIComponent(tagName)}`;
// 2ページ目以降は一覧の内容が薄く、正規URLと重複しやすいためインデックス対象から外す。
const noindex = page > 1;

const user = Astro.locals.user;

const [itemsPage, topTags, sources, bookmarkedItemIds] = await Promise.all([
	fetchCatalogItemsPage({ tag: tagName, page }),
	fetchTopTags(20),
	fetchCatalogSources({ tag: tagName }),
	user ? fetchBookmarkedItemIds(Astro.request, Astro.cookies, user.id) : Promise.resolve(new Set<number>()),
]);

// このタグの代表記事（一覧先頭）が持つ「他のタグ」を手がかりに、タグ横断の関連記事を提案する。
// このタグ自体での重なりは（ページを問わず）このタグの一覧で既に見られるため除外し、
// 別の関心軸からの発見を狙う。
const representativeItem = itemsPage.items[0] ?? null;
const relatedTagIds = representativeItem
	? representativeItem.tags.filter((tag) => tag.name !== tagName).map((tag) => tag.id)
	: [];
const relatedItems: CatalogItem[] = representativeItem && relatedTagIds.length > 0
	? await fetchRelatedItems(await resolveItemIdsByTag(tagName), relatedTagIds, { limit: 4 })
	: [];
---

<Layout
	title={`#${tagLabel} の記事一覧 | ${topic.site.name}`}
	description={`「${tagLabel}」タグが付いた${topic.collection.label}プログラミング関連記事の一覧です。`}
	loggedIn={Boolean(user)}
	canonicalPath={canonicalPath}
	noindex={noindex}
>
	<CatalogPage
		eyebrow="Tag"
		basePath="/items"
		items={itemsPage.items}
		topTags={topTags}
		sources={sources}
		filters={{ q: '', tags: [tagName], sourceIds: [], sort: 'new' }}
		pagination={{ page: itemsPage.page, totalPages: itemsPage.totalPages, total: itemsPage.total }}
		bookmarkedItemIds={bookmarkedItemIds}
		loggedIn={Boolean(user)}
	/>

	{relatedItems.length > 0 ? (
		<section class="related">
			<p class="eyebrow">Related articles</p>
			<div class="related-cards">
				{relatedItems.map((item) => (
					<ItemCard
						item={item}
						bookmarked={bookmarkedItemIds.has(item.id)}
						bookmarkCount={item.bookmarks_count ?? 0}
						loggedIn={Boolean(user)}
					/>
				))}
			</div>
		</section>
	) : null}
</Layout>

<style>
	.related {
		display: grid;
		gap: 14px;
		margin-top: 24px;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.related-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 18px;
	}
</style>
