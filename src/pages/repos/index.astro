---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CatalogPage from '../../components/CatalogPage.astro';
import { fetchBookmarkedItemIds, fetchCatalogItemsPage, fetchCatalogSources, fetchTopTags } from '../../lib/catalog';
import { parseOptionalPositiveInteger } from '../../lib/params';
import { topic } from '../../config/topic.config.mjs';

const url = new URL(Astro.request.url);
const sourceIds = url.searchParams
	.getAll('sourceId')
	.map((value) => parseOptionalPositiveInteger(value))
	.filter((value): value is number => value !== undefined);
const sortParam = url.searchParams.get('sort');
const sort =
	sortParam === 'popular' ? 'popular'
	: sortParam === 'oldest' ? 'oldest'
	: sortParam === 'relevance' ? 'relevance'
	: 'new';

// 期間フィルタ: 公開日の下限へ変換する。不正値は「全期間」として無視する。
const PERIOD_DAYS: Record<string, number> = { '1m': 30, '6m': 182, '1y': 365 };
const periodParam = url.searchParams.get('period') ?? '';
const period = periodParam in PERIOD_DAYS ? periodParam : '';
const since = period ? new Date(Date.now() - PERIOD_DAYS[period] * 24 * 60 * 60 * 1000).toISOString() : undefined;

const filters = {
	q: url.searchParams.get('q') ?? '',
	// ?tag=a&tag=b の複数指定を AND 条件として受ける。
	tags: url.searchParams.getAll('tag').map((tag) => tag.trim()).filter((tag) => tag.length > 0),
	sourceIds,
	sort,
	period,
};
const page = parseOptionalPositiveInteger(url.searchParams.get('page')) ?? 1;

// タグページ（/tags/{name}）は記事・論文・リポジトリのkindを横断する既存の仕組みのため、
// items/index.astroのような単一タグ時のcanonical正規化はここでは行わず、
// 検索条件付きのURLは常に/repos（クエリなし）へ寄せる（papers/index.astroと同方針）。
const hasAnyQueryParam =
	url.searchParams.has('q') ||
	url.searchParams.has('tag') ||
	url.searchParams.has('sourceId') ||
	url.searchParams.has('sort') ||
	url.searchParams.has('period') ||
	url.searchParams.has('page');
const canonicalPath = '/repos';

const user = Astro.locals.user;

const [itemsPage, topTags, sources, bookmarkedItemIds] = await Promise.all([
	fetchCatalogItemsPage({
		q: filters.q || undefined,
		kind: 'repo',
		tags: filters.tags.length > 0 ? filters.tags : undefined,
		sourceIds: filters.sourceIds.length > 0 ? filters.sourceIds : undefined,
		since,
		sort: filters.sort,
		page,
	}),
	fetchTopTags(20, 'repo'),
	fetchCatalogSources({
		q: filters.q || undefined,
		kind: 'repo',
		tags: filters.tags.length > 0 ? filters.tags : undefined,
		since,
		sourceIds: filters.sourceIds,
	}),
	user ? fetchBookmarkedItemIds(Astro.request, Astro.cookies, user.id) : Promise.resolve(new Set<number>()),
]);
---

<Layout
	title={`リポジトリ | ${topic.site.name}`}
	description="GitHubリポジトリの一覧・検索画面"
	loggedIn={Boolean(user)}
	canonicalPath={canonicalPath}
	noindex={hasAnyQueryParam}
>
	<CatalogPage
		eyebrow="Repositories"
		basePath="/repos"
		items={itemsPage.items}
		topTags={topTags}
		sources={sources}
		filters={filters}
		pagination={{ page: itemsPage.page, totalPages: itemsPage.totalPages, total: itemsPage.total }}
		bookmarkedItemIds={bookmarkedItemIds}
		loggedIn={Boolean(user)}
	/>
</Layout>
